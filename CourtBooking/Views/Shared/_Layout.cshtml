@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject CourtBooking.Data.ApplicationDbContext _layoutDb
@{
    // Custom branding only applies to the logged-in admin viewing their own pages.
    // Guests, customers, and the login page always show "CourtBook".
    var _uid     = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var _fs      = User.IsInRole("Admin") && _uid != null
                     ? await _layoutDb.FacilitySettings.FirstOrDefaultAsync(s => s.OwnerId == _uid)
                     : null;
    var _brand   = (User.IsInRole("Admin") ? _fs?.DisplayName    : null) ?? "CourtBook";
    var _tagline = (User.IsInRole("Admin") ? _fs?.DisplayTagline : null) ?? "Book your court anytime, anywhere.";
    var _logoUrl = User.IsInRole("Admin") ? _fs?.BrandLogoUrl : null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @_brand</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="CourtBook" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrWhiteSpace(_logoUrl))
                {
                    <img src="@_logoUrl" alt="@_brand" style="height:32px;max-width:160px;object-fit:contain;" />
                }
                else
                {
                    <i class="bi bi-trophy-fill me-2"></i>@_brand
                }
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Courts" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Courts
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bookings" asp-action="My">
                                <i class="bi bi-calendar-check me-1"></i>My Bookings
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-gear me-1"></i>Admin
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Courts"><i class="bi bi-buildings me-2"></i>Manage Courts</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Sports"><i class="bi bi-trophy me-2"></i>Manage Sports</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Bookings"><i class="bi bi-calendar3 me-2"></i>All Bookings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Reviews" asp-action="Index"><i class="bi bi-chat-quote me-2"></i>Share Your Story</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login"
                               asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item d-none" id="pwaInstallItem">
                            <button class="btn btn-outline-light btn-sm ms-2 my-1" id="pwaInstallBtn">
                                <i class="bi bi-download me-1"></i>Install App
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>


    @* ── Suspended banner (admin only — highest priority) ──────────────── *@
    @if (User.IsInRole("Admin") && _fs is not null && _fs.IsSuspended)
    {
        <div class="trial-banner trial-banner-urgent">
            <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-cone-striped"></i>
                    <span>
                        <strong>Your facility is suspended.</strong>
                        @if (!string.IsNullOrWhiteSpace(_fs.SuspendedReason))
                        {
                            <span>Reason: @_fs.SuspendedReason.</span>
                        }
                        Customers cannot view your courts or make new bookings. Please contact support to resolve this.
                    </span>
                </div>
                <a href="mailto:courtbooksolutions@gmail.com"
                   class="btn btn-sm btn-dark fw-semibold text-nowrap">
                    <i class="bi bi-envelope me-1"></i>Contact Support
                </a>
            </div>
        </div>
    }

    @* ── Grace-period / Downgraded banner (admin only) ─────────────────── *@
    @if (User.IsInRole("Admin") && _fs is not null && (_fs.IsInGracePeriod || _fs.IsDowngraded))
    {
        var inGrace      = _fs.IsInGracePeriod;
        var graceLeft    = _fs.GraceDaysRemaining;
        var sinceExpiry  = _fs.DaysSinceExpiry;
        <div class="trial-banner trial-banner-urgent">
            <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi @(inGrace ? "bi-exclamation-triangle-fill" : "bi-x-octagon-fill")"></i>
                    @if (inGrace)
                    {
                        <span>
                            <strong>Your subscription expired @sinceExpiry day@(sinceExpiry == 1 ? "" : "s") ago.</strong>
                            Pro features stay on for @graceLeft more day@(graceLeft == 1 ? "" : "s") — renew now to avoid downgrade.
                        </span>
                    }
                    else
                    {
                        <span>
                            <strong>Pro features are paused.</strong>
                            Your subscription expired @sinceExpiry day@(sinceExpiry == 1 ? "" : "s") ago and the grace period has ended.
                            Renew anytime to restore your branding instantly.
                        </span>
                    }
                </div>
                <a asp-controller="Subscription" asp-action="Upgrade"
                   class="btn btn-sm btn-dark fw-semibold text-nowrap">
                    <i class="bi bi-arrow-repeat me-1"></i>Renew Now
                </a>
            </div>
        </div>
    }

    <main class="pb-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
                <div class="container">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
                <div class="container">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1"><strong>@_brand</strong> &mdash; @_tagline</p>
            <small class="text-white-50">
                &copy; @DateTime.Now.Year @_brand. All rights reserved.
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none">About Us</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none">Terms</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none">Privacy</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Donate" class="text-danger text-decoration-none">
                    <i class="bi bi-heart-fill" style="font-size:.75rem;vertical-align:-1px;"></i> Support Us
                </a>
            </small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Service worker registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }

        // PWA install prompt
        let _deferredInstall;
        window.addEventListener('beforeinstallprompt', e => {
            e.preventDefault();
            _deferredInstall = e;
            document.getElementById('pwaInstallItem')?.classList.remove('d-none');
        });
        document.getElementById('pwaInstallBtn')?.addEventListener('click', async () => {
            if (!_deferredInstall) return;
            _deferredInstall.prompt();
            const { outcome } = await _deferredInstall.userChoice;
            if (outcome === 'accepted') {
                document.getElementById('pwaInstallItem')?.classList.add('d-none');
            }
            _deferredInstall = null;
        });
        window.addEventListener('appinstalled', () => {
            document.getElementById('pwaInstallItem')?.classList.add('d-none');
        });
    </script>
</body>
</html>
