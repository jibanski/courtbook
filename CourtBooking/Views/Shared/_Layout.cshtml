@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@inject CourtBooking.Data.ApplicationDbContext _layoutDb
@inject UserManager<CourtBooking.Models.ApplicationUser> _layoutUsers
@{
    // Branding source: for admins, their own facility; for customers, the
    // facility they're pinned to (PreferredFacilitySlug). Guests fall back
    // to the only facility on this install (single-tenant deployments) or
    // to the generic platform name.
    var _uid = User.FindFirstValue(ClaimTypes.NameIdentifier);
    CourtBooking.Models.FacilitySettings? _fs = null;

    if (User.IsInRole("Admin") && _uid != null)
    {
        _fs = await _layoutDb.FacilitySettings.AsNoTracking()
            .FirstOrDefaultAsync(s => s.OwnerId == _uid);
    }
    else if (User.Identity?.IsAuthenticated == true && _uid != null)
    {
        var slug = (await _layoutUsers.FindByIdAsync(_uid))?.PreferredFacilitySlug;
        if (!string.IsNullOrEmpty(slug))
        {
            _fs = await _layoutDb.FacilitySettings.AsNoTracking()
                .FirstOrDefaultAsync(s => s.Slug == slug);
        }
    }

    // Single-tenant fallback: if no contextual facility was resolved and only one
    // facility exists on this install, use it for everyone (including guests).
    if (_fs == null)
    {
        var onlyFacility = await _layoutDb.FacilitySettings.AsNoTracking()
            .OrderBy(s => s.Id).Take(2).ToListAsync();
        if (onlyFacility.Count == 1) _fs = onlyFacility[0];
    }

    var _brand   = _fs?.DisplayName    ?? "CourtBook";
    var _tagline = _fs?.DisplayTagline ?? "Book your court anytime, anywhere.";
    var _logoUrl = _fs?.BrandLogoUrl;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @_brand</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#071827" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="@_brand" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg cb-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                @if (!string.IsNullOrWhiteSpace(_logoUrl))
                {
                    <img src="@_logoUrl" alt="@_brand" style="height:30px;max-width:160px;object-fit:contain;" />
                }
                else
                {
                    <span class="brand-icon"><i class="bi bi-lightning-charge-fill"></i></span>
                    <span>@_brand</span>
                }
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Courts" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Courts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bookings" asp-action="My">
                                <i class="bi bi-calendar-check me-1"></i>My Bookings
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-grid me-1"></i>Manage
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Courts"><i class="bi bi-buildings me-2 text-info"></i>Courts</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Sports"><i class="bi bi-trophy me-2 text-warning"></i>Sports</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Bookings"><i class="bi bi-calendar3 me-2 text-success"></i>All Bookings</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Analytics"><i class="bi bi-graph-up-arrow me-2 text-success"></i>Analytics <span class="badge bg-success-subtle text-success-emphasis ms-1" style="font-size:.65rem;">Live</span></a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Reviews" asp-action="Index"><i class="bi bi-chat-quote me-2 text-info"></i>Share Story</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings"><i class="bi bi-sliders me-2 text-primary"></i>Settings</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary"
                                      style="width:28px;height:28px;font-size:.75rem;color:#071827;font-weight:700;flex-shrink:0;">
                                    @(User.Identity.Name?.Substring(0,1).ToUpper())
                                </span>
                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person-circle me-2" style="color:var(--cb-lime);"></i>My Profile
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login"
                               asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item d-none" id="pwaInstallItem">
                            <button class="btn btn-outline-secondary btn-sm ms-1" id="pwaInstallBtn">
                                <i class="bi bi-download me-1"></i>Install
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>


    @* ── Suspended banner (admin only — highest priority) ──────────────── *@
    @if (User.IsInRole("Admin") && _fs is not null && _fs.IsSuspended)
    {
        <div class="trial-banner trial-banner-urgent">
            <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-cone-striped"></i>
                    <span>
                        <strong>Your facility is suspended.</strong>
                        @if (!string.IsNullOrWhiteSpace(_fs.SuspendedReason))
                        {
                            <span>Reason: @_fs.SuspendedReason.</span>
                        }
                        Customers cannot view your courts or make new bookings. Please contact support to resolve this.
                    </span>
                </div>
                <a href="mailto:courtbooksolutions@gmail.com"
                   class="btn btn-sm btn-dark fw-semibold text-nowrap">
                    <i class="bi bi-envelope me-1"></i>Contact Support
                </a>
            </div>
        </div>
    }

    @* ── Deactivated banner (owner self-service — reversible) ──────────── *@
    @if (User.IsInRole("Admin") && _fs is not null && _fs.IsDeactivated && !_fs.IsSuspended)
    {
        <div class="trial-banner trial-banner-urgent">
            <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-power"></i>
                    <span>
                        <strong>Your facility is deactivated.</strong>
                        Customers cannot view your courts or make new bookings. Reactivate whenever you're ready.
                    </span>
                </div>
                <form asp-controller="Admin" asp-action="ReactivateFacility" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-dark fw-semibold text-nowrap">
                        <i class="bi bi-arrow-clockwise me-1"></i>Reactivate
                    </button>
                </form>
            </div>
        </div>
    }

    @* ── Grace-period / Downgraded banner (admin only) ─────────────────── *@
    @if (User.IsInRole("Admin") && _fs is not null && (_fs.IsInGracePeriod || _fs.IsDowngraded))
    {
        var inGrace      = _fs.IsInGracePeriod;
        var graceLeft    = _fs.GraceDaysRemaining;
        var sinceExpiry  = _fs.DaysSinceExpiry;
        <div class="trial-banner trial-banner-urgent">
            <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2 py-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi @(inGrace ? "bi-exclamation-triangle-fill" : "bi-x-octagon-fill")"></i>
                    @if (inGrace)
                    {
                        <span>
                            <strong>Your subscription expired @sinceExpiry day@(sinceExpiry == 1 ? "" : "s") ago.</strong>
                            Pro features stay on for @graceLeft more day@(graceLeft == 1 ? "" : "s") — renew now to avoid downgrade.
                        </span>
                    }
                    else
                    {
                        <span>
                            <strong>Pro features are paused.</strong>
                            Your subscription expired @sinceExpiry day@(sinceExpiry == 1 ? "" : "s") ago and the grace period has ended.
                            Renew anytime to restore your branding instantly.
                        </span>
                    }
                </div>
                <a asp-controller="Subscription" asp-action="Upgrade"
                   class="btn btn-sm btn-dark fw-semibold text-nowrap">
                    <i class="bi bi-arrow-repeat me-1"></i>Renew Now
                </a>
            </div>
        </div>
    }

    <main class="pb-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
                <div class="container">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
                <div class="container">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="cb-footer">
        <div class="container">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-2 bg-primary"
                          style="width:24px;height:24px;font-size:.7rem;color:#071827;flex-shrink:0;">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </span>
                    <div>
                        <span class="brand-name fw-bold small">@_brand</span>
                        <span class="tagline ms-2">&mdash; @_tagline</span>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3 flex-wrap justify-content-center">
                    <span class="tagline">&copy; @DateTime.Now.Year @_brand</span>
                    <a asp-controller="Home" asp-action="About">About</a>
                    <a asp-controller="Home" asp-action="Terms">Terms</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a asp-controller="Home" asp-action="Donate" class="support-link d-inline-flex align-items-center gap-1">
                        <i class="bi bi-heart-fill" style="font-size:.7rem;"></i>Support Us
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Service worker registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }

        // PWA install prompt
        let _deferredInstall;
        window.addEventListener('beforeinstallprompt', e => {
            e.preventDefault();
            _deferredInstall = e;
            document.getElementById('pwaInstallItem')?.classList.remove('d-none');
        });
        document.getElementById('pwaInstallBtn')?.addEventListener('click', async () => {
            if (!_deferredInstall) return;
            _deferredInstall.prompt();
            const { outcome } = await _deferredInstall.userChoice;
            if (outcome === 'accepted') {
                document.getElementById('pwaInstallItem')?.classList.add('d-none');
            }
            _deferredInstall = null;
        });
        window.addEventListener('appinstalled', () => {
            document.getElementById('pwaInstallItem')?.classList.add('d-none');
        });
    </script>
</body>
</html>
