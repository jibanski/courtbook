<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CourtBook</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="CourtBook" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="landing-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light landing-nav sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 text-primary" asp-controller="Home" asp-action="Index">
                <i class="bi bi-trophy-fill me-2 text-warning"></i>CourtBook
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#landingNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="landingNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" href="#how-it-works">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" href="#faq">FAQ</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login</a>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Customer" class="btn btn-outline-primary">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="btn btn-primary fw-semibold px-4">
                        <i class="bi bi-rocket-takeoff me-1"></i>Start Free Trial
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="landing-footer py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="fw-bold fs-5 mb-2 text-white">
                        <i class="bi bi-trophy-fill me-2 text-warning"></i>CourtBook
                    </div>
                    <p class="text-white-50 small">
                        The smart booking platform built for sports facility owners.
                        Accept bookings, collect payments, and grow your business — all in one place.
                    </p>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Product</div>
                    <ul class="list-unstyled">
                        <li><a href="#features" class="text-white-50 text-decoration-none small">Features</a></li>
                        <li><a href="#how-it-works" class="text-white-50 text-decoration-none small">How It Works</a></li>
                        <li><a href="#pricing" class="text-white-50 text-decoration-none small">Pricing</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Account</div>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="text-white-50 text-decoration-none small">Start Free Trial</a></li>
                        <li><a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none small">Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Company</div>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none small">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none small">Terms of Service</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none small">Privacy Policy</a></li>
                        <li><a asp-controller="Home" asp-action="Donate" class="text-warning text-decoration-none small"><i class="bi bi-heart-fill me-1"></i>Support Us</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <div class="text-white fw-semibold mb-3">Get Started Today</div>
                    <p class="text-white-50 small">Free for facility owners and players. No credit card, no subscription.</p>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-rocket-takeoff me-1"></i>Create Free Account
                    </a>
                </div>
            </div>
            <hr class="border-secondary mt-4" />
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year CourtBook. All rights reserved.
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none">About Us</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none">Terms</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none">Privacy</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Donate" class="text-warning text-decoration-none"><i class="bi bi-heart-fill me-1"></i>Support Us</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
</body>
</html>
