<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CourtBook</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#071827" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="CourtBook" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body class="landing-body">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg cb-navbar sticky-top" style="background:#050D18!important;border-bottom:1px solid rgba(255,255,255,0.07);">
        <div class="container">
            <a class="navbar-brand fw-bold fs-5 d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index"
               style="color:var(--cb-text);text-decoration:none;">
                <span class="d-inline-flex align-items-center justify-content-center rounded-2"
                      style="width:28px;height:28px;background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.25);">
                    <i class="bi bi-lightning-charge-fill" style="color:var(--cb-lime);font-size:.8rem;"></i>
                </span>
                CourtBook
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#landingNav"
                    style="color:var(--cb-text-2);">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="landingNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="#features" style="color:var(--cb-text-2);font-size:.9rem;">Features</a></li>
                    <li class="nav-item"><a class="nav-link" href="#how-it-works" style="color:var(--cb-text-2);font-size:.9rem;">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#pricing" style="color:var(--cb-text-2);font-size:.9rem;">Free &amp; Support</a></li>
                    <li class="nav-item"><a class="nav-link" href="#faq" style="color:var(--cb-text-2);font-size:.9rem;">FAQ</a></li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-secondary">Login</a>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Customer" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="btn btn-sm btn-primary fw-semibold px-3">
                        <i class="bi bi-rocket-takeoff me-1"></i>Get Started Free
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="landing-footer py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="fw-bold fs-5 mb-2 text-white">
                        <i class="bi bi-trophy-fill me-2 text-warning"></i>CourtBook
                    </div>
                    <p class="text-white-50 small">
                        The smart booking platform built for sports facility owners.
                        Accept bookings, collect payments, and grow your business — all in one place.
                    </p>
                    <a href="https://www.facebook.com/CourtBookSolutions" target="_blank" rel="noopener"
                       class="d-inline-flex align-items-center gap-2 text-decoration-none px-3 py-2 rounded-3 mt-1"
                       style="background:rgba(24,119,242,0.12);border:1px solid rgba(24,119,242,0.2);color:#93c5fd;font-size:.82rem;">
                        <i class="bi bi-facebook" style="color:#1877f2;font-size:.95rem;"></i>
                        Follow us on Facebook
                    </a>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Product</div>
                    <ul class="list-unstyled">
                        <li><a href="#features" class="text-white-50 text-decoration-none small">Features</a></li>
                        <li><a href="#how-it-works" class="text-white-50 text-decoration-none small">How It Works</a></li>
                        <li><a href="#pricing" class="text-white-50 text-decoration-none small">Free &amp; Support</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Account</div>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="text-white-50 text-decoration-none small">Create Free Account</a></li>
                        <li><a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none small">Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <div class="text-white fw-semibold mb-3">Company</div>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none small">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none small">Terms of Service</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none small">Privacy Policy</a></li>
                        <li><a asp-controller="Home" asp-action="Donate" class="text-warning text-decoration-none small"><i class="bi bi-heart-fill me-1"></i>Support Us</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <div class="text-white fw-semibold mb-3">Get Started Today</div>
                    <p class="text-white-50 small">Free for facility owners and players. No credit card, no subscription.</p>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-rocket-takeoff me-1"></i>Create Free Account
                    </a>
                </div>
            </div>
            <hr class="border-secondary mt-4" />
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year CourtBook. All rights reserved.
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none">About Us</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none">Terms</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none">Privacy</a>
                &nbsp;&middot;&nbsp;
                <a asp-controller="Home" asp-action="Donate" class="text-warning text-decoration-none d-inline-flex align-items-center gap-1"><i class="bi bi-heart-fill" style="font-size:.75rem;"></i>Support Us</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
</body>
</html>
