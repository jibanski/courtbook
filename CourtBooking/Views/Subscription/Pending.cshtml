@{
    var isRenewal    = ViewBag.IsRenewal == true;
    ViewData["Title"] = isRenewal ? "Renewal Submitted" : "Payment Submitted";
    var settings     = ViewBag.Settings as CourtBooking.Models.FacilitySettings;
    var contactEmail = ViewBag.ContactEmail as string ?? "sales@courtbook.com";
    var contactPhone = ViewBag.ContactPhone as string ?? "";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 text-center">

            <!-- Status icon -->
            <div class="d-inline-flex align-items-center justify-content-center bg-warning-subtle rounded-circle mb-4"
                 style="width:96px;height:96px;">
                <i class="bi bi-hourglass-split text-warning" style="font-size:3rem;"></i>
            </div>

            <h1 class="fw-bold mb-2">@(isRenewal ? "Renewal Submitted!" : "Payment Submitted!")</h1>
            <p class="text-muted lead mb-4">
                @if (isRenewal)
                {
                    <span>Your renewal payment is in. We'll verify the transaction and email you a new <strong>activation key</strong> within 24 hours. Your current Pro access continues uninterrupted while we verify.</span>
                }
                else
                {
                    <span>We've received your payment details and are verifying your transaction. You'll receive an <strong>activation key</strong> within 24 hours.</span>
                }
            </p>

            <!-- Submission summary -->
            @if (settings?.SubscriptionSubmittedAt.HasValue == true)
            {
                <div class="bg-white rounded-4 shadow-sm p-4 mb-4 text-start">
                    <h6 class="fw-bold mb-3"><i class="bi bi-receipt me-2 text-primary"></i>Submission Summary</h6>
                    <div class="row g-2">
                        <div class="col-5 text-muted small">Plan</div>
                        <div class="col-7 fw-semibold small text-capitalize">
                            @(settings.SubscriptionPlan == "annual" ? "Annual Plan" : "Monthly Plan")
                        </div>
                        <div class="col-5 text-muted small">Reference #</div>
                        <div class="col-7 fw-semibold small">@settings.SubscriptionPaymentRef</div>
                        <div class="col-5 text-muted small">Submitted</div>
                        <div class="col-7 fw-semibold small">
                            @settings.SubscriptionSubmittedAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                        </div>
                        <div class="col-5 text-muted small">Status</div>
                        <div class="col-7">
                            <span class="badge bg-warning text-dark">Pending Verification</span>
                        </div>
                    </div>
                </div>
            }

            <!-- Next steps -->
            <div class="bg-white rounded-4 shadow-sm p-4 mb-4 text-start">
                <h6 class="fw-bold mb-3"><i class="bi bi-list-check me-2 text-primary"></i>What happens next?</h6>
                <ol class="ps-3 text-muted small mb-0">
                    <li class="mb-2">Our team verifies your payment (within 24 hours on business days).</li>
                    <li class="mb-2">We email your <strong>activation key</strong> to your registered email address.</li>
                    <li class="mb-2">Go to <strong>Admin → Settings → Subscription</strong> and enter the key to unlock Pro.</li>
                    <li>Enjoy full uninterrupted access to CourtBook Pro!</li>
                </ol>
            </div>

            <!-- Contact -->
            <div class="bg-light rounded-4 p-4 mb-4 text-start">
                <h6 class="fw-bold mb-3"><i class="bi bi-headset me-2"></i>Need help?</h6>
                <div class="d-flex flex-column gap-2">
                    <a href="mailto:@contactEmail" class="d-flex align-items-center gap-2 text-decoration-none text-dark small">
                        <i class="bi bi-envelope-fill text-primary"></i>@contactEmail
                    </a>
                    @if (!string.IsNullOrEmpty(contactPhone))
                    {
                        <a href="tel:@contactPhone" class="d-flex align-items-center gap-2 text-decoration-none text-dark small">
                            <i class="bi bi-telephone-fill text-success"></i>@contactPhone
                        </a>
                    }
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-speedometer2 me-1"></i>Back to Dashboard
                </a>
                <a asp-controller="Subscription" asp-action="Upgrade" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-repeat me-1"></i>Resubmit
                </a>
            </div>
        </div>
    </div>
</div>
