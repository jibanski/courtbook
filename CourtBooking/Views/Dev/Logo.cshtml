@using CourtBooking.Models
@{
    Layout = null;
    ViewData["Title"] = "CourtBook — Platform Logo";

    var password   = ViewBag.Password  as string ?? "";
    var errorMsg   = ViewBag.Error     as string;
    var isUnlocked = (bool)(ViewBag.IsUnlocked ?? false);
    var cfg        = ViewBag.Config    as PlatformConfig;

    string? LogoSrc = cfg?.LogoData is { Length: > 0 }
        ? $"data:{cfg.LogoContentType};base64,{Convert.ToBase64String(cfg.LogoData)}"
        : null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body                          { background:#0d1117; color:#e6edf3; }
        .dev-card                     { background:#161b22; border:1px solid #30363d; border-radius:12px; }
        .form-control, .form-select   { background:#0d1117; border-color:#30363d; color:#e6edf3; }
        .form-control:focus           { background:#0d1117; border-color:#58a6ff; color:#e6edf3; box-shadow:none; }
        .nav-link                     { color:#58a6ff !important; font-size:.85rem; }
        .logo-preview                 { max-width:240px; max-height:120px; object-fit:contain; border-radius:8px; background:#fff; padding:10px; }
        .logo-preview-dark            { max-width:240px; max-height:120px; object-fit:contain; border-radius:8px; background:#050D18; padding:10px; border:1px solid #30363d; }
    </style>
</head>
<body>
<div class="container py-5" style="max-width:640px;">

    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 rounded-circle mb-3"
             style="width:64px;height:64px;">
            <i class="bi bi-image-fill text-warning fs-2"></i>
        </div>
        <h3 class="fw-bold mb-1">Platform Logo</h3>
        <p class="text-secondary small mb-0">Upload the CourtBook logo shown in the landing page navbar &amp; footer</p>
        <div class="mt-1">
            <a href="/Dev/Facilities" class="nav-link d-inline-block">Facilities</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Subscriptions" class="nav-link d-inline-block">Subscriptions</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Reviews" class="nav-link d-inline-block">Reviews</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/KeyGen" class="nav-link d-inline-block">Key Generator</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/DonationQr" class="nav-link d-inline-block">Donation QR</a>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> @ok
        </div>
    }

    @if (!isUnlocked)
    {
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }
        <div class="dev-card p-4">
            <form method="post" asp-action="Logo" asp-controller="Dev">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">
                        <i class="bi bi-shield-lock me-1"></i>Developer Password
                    </label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Enter developer password" autofocus required />
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark">
                    <i class="bi bi-unlock me-2"></i>Unlock
                </button>
            </form>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }

        <div class="dev-card p-4">
            <div class="mb-4">
                <label class="form-label fw-semibold mb-2">Current Logo</label>
                @if (LogoSrc != null)
                {
                    <div class="d-flex gap-3 flex-wrap align-items-center">
                        <div>
                            <div class="text-secondary small mb-1">On light background</div>
                            <img src="@LogoSrc" alt="Logo preview" class="logo-preview" />
                        </div>
                        <div>
                            <div class="text-secondary small mb-1">On landing-page navbar</div>
                            <img src="@LogoSrc" alt="Logo preview" class="logo-preview-dark" />
                        </div>
                    </div>
                    <div class="mt-2 small text-success">
                        <i class="bi bi-check-circle me-1"></i>Logo is live on the landing page.
                    </div>
                }
                else
                {
                    <div class="text-secondary small">
                        <i class="bi bi-image me-1"></i>No logo uploaded. The landing page is using the default
                        <i class="bi bi-lightning-charge-fill text-warning"></i> icon.
                    </div>
                }
            </div>

            <hr class="border-secondary" />

            <form method="post" asp-action="Logo" asp-controller="Dev" enctype="multipart/form-data" class="mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="password" value="@password" />

                <label class="form-label fw-semibold">Upload New Logo</label>
                <input type="file" name="logo" class="form-control mb-2"
                       accept="image/png,image/jpeg,image/webp,image/svg+xml"
                       onchange="previewLogo(this)" required />
                <img id="logoPreview" src="" class="logo-preview-dark mt-2 d-none" alt="Preview" />
                <div class="form-text text-secondary">
                    PNG, JPG, WEBP, or SVG. Max 1 MB. Transparent background recommended (the landing-page navbar is dark).
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark mt-3">
                    <i class="bi bi-cloud-upload me-2"></i>Save Logo
                </button>
            </form>

            @if (LogoSrc != null)
            {
                <form method="post" asp-action="Logo" asp-controller="Dev"
                      onsubmit="return confirm('Remove the current logo and revert to the default icon?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="password" value="@password" />
                    <input type="hidden" name="action" value="remove" />
                    <button type="submit" class="btn btn-outline-danger w-100 fw-semibold">
                        <i class="bi bi-trash me-2"></i>Remove Logo
                    </button>
                </form>
            }
        </div>
    }

</div>
<script>
    function previewLogo(input) {
        const preview = document.getElementById('logoPreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => { preview.src = e.target.result; preview.classList.remove('d-none'); };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
</body>
</html>
