@using CourtBooking.Models
@{
    Layout = null;
    ViewData["Title"] = "CourtBook — Donation QR Codes";

    var password   = ViewBag.Password  as string ?? "";
    var errorMsg   = ViewBag.Error     as string;
    var isUnlocked = (bool)(ViewBag.IsUnlocked ?? false);
    var cfg        = ViewBag.Config    as PlatformConfig;

    string? GcashSrc     = cfg?.GCashQrData     is { Length: > 0 } ? $"data:{cfg.GCashQrContentType};base64,{Convert.ToBase64String(cfg.GCashQrData)}"         : null;
    string? MayaSrc      = cfg?.MayaQrData      is { Length: > 0 } ? $"data:{cfg.MayaQrContentType};base64,{Convert.ToBase64String(cfg.MayaQrData)}"           : null;
    string? MetrobankSrc = cfg?.MetrobankQrData  is { Length: > 0 } ? $"data:{cfg.MetrobankQrContentType};base64,{Convert.ToBase64String(cfg.MetrobankQrData)}" : null;
    string? BpiSrc       = cfg?.BpiQrData        is { Length: > 0 } ? $"data:{cfg.BpiQrContentType};base64,{Convert.ToBase64String(cfg.BpiQrData)}"             : null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body       { background:#0d1117; color:#e6edf3; }
        .dev-card  { background:#161b22; border:1px solid #30363d; border-radius:12px; }
        .form-control, .form-select { background:#0d1117; border-color:#30363d; color:#e6edf3; }
        .form-control:focus { background:#0d1117; border-color:#58a6ff; color:#e6edf3; box-shadow:none; }
        .nav-link  { color:#58a6ff !important; font-size:.85rem; }
        .qr-preview { width:160px; height:160px; object-fit:contain; border-radius:8px; background:#fff; padding:6px; }
    </style>
</head>
<body>
<div class="container py-5" style="max-width:640px;">

    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle mb-3"
             style="width:64px;height:64px;">
            <i class="bi bi-qr-code text-danger fs-2"></i>
        </div>
        <h3 class="fw-bold mb-1">Donation QR Codes</h3>
        <p class="text-secondary small mb-0">Upload GCash, Maya, Metrobank, and BPI QR codes shown on the donation page</p>
        <div class="mt-1">
            <a href="/Dev/Facilities" class="nav-link d-inline-block">Facilities</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Subscriptions" class="nav-link d-inline-block">Subscriptions</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Reviews" class="nav-link d-inline-block">Reviews</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/KeyGen" class="nav-link d-inline-block">Key Generator</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Logo" class="nav-link d-inline-block">Platform Logo</a>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> @ok
        </div>
    }

    @if (!isUnlocked)
    {
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }
        <div class="dev-card p-4">
            <form method="post" asp-action="DonationQr" asp-controller="Dev">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">
                        <i class="bi bi-shield-lock me-1"></i>Developer Password
                    </label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Enter developer password" autofocus required />
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark">
                    <i class="bi bi-unlock me-2"></i>Unlock
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="dev-card p-4">
            <form method="post" asp-action="DonationQr" asp-controller="Dev" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="password" value="@password" />

                <!-- GCash QR -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/GCash_Logo.svg/120px-GCash_Logo.svg.png"
                             height="20" class="me-2" alt="GCash" />GCash QR Code
                    </label>
                    @if (GcashSrc != null)
                    {
                        <div class="mb-2">
                            <img src="@GcashSrc" alt="GCash QR" class="qr-preview d-block mb-1" />
                            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>QR uploaded</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-secondary small mb-2"><i class="bi bi-image me-1"></i>No QR uploaded yet</div>
                    }
                    <input type="file" name="gcashQr" class="form-control"
                           accept="image/png,image/jpeg,image/webp"
                           onchange="previewQr(this,'gcashPreview')" />
                    <img id="gcashPreview" src="" class="qr-preview mt-2 d-none" alt="Preview" />
                    <div class="form-text text-secondary">PNG or JPG. The QR will be shown on the Donate page.</div>
                </div>

                <!-- Maya QR -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <span class="text-primary fw-bold me-2" style="font-size:1rem;">Maya</span>QR Code
                    </label>
                    @if (MayaSrc != null)
                    {
                        <div class="mb-2">
                            <img src="@MayaSrc" alt="Maya QR" class="qr-preview d-block mb-1" />
                            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>QR uploaded</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-secondary small mb-2"><i class="bi bi-image me-1"></i>No QR uploaded yet</div>
                    }
                    <input type="file" name="mayaQr" class="form-control"
                           accept="image/png,image/jpeg,image/webp"
                           onchange="previewQr(this,'mayaPreview')" />
                    <img id="mayaPreview" src="" class="qr-preview mt-2 d-none" alt="Preview" />
                    <div class="form-text text-secondary">PNG or JPG. The QR will be shown on the Donate page.</div>
                </div>

                <!-- Metrobank QR -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <span class="fw-bold me-2" style="color:#003087;">Metrobank</span>QR Code
                    </label>
                    @if (MetrobankSrc != null)
                    {
                        <div class="mb-2">
                            <img src="@MetrobankSrc" alt="Metrobank QR" class="qr-preview d-block mb-1" />
                            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>QR uploaded</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-secondary small mb-2"><i class="bi bi-image me-1"></i>No QR uploaded yet</div>
                    }
                    <input type="file" name="metrobankQr" class="form-control"
                           accept="image/png,image/jpeg,image/webp"
                           onchange="previewQr(this,'metrobankPreview')" />
                    <img id="metrobankPreview" src="" class="qr-preview mt-2 d-none" alt="Preview" />
                    <div class="form-text text-secondary">PNG or JPG. The QR will be shown on the Donate page.</div>
                </div>

                <!-- BPI QR -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <span class="fw-bold me-2" style="color:#c8102e;">BPI</span>QR Code
                    </label>
                    @if (BpiSrc != null)
                    {
                        <div class="mb-2">
                            <img src="@BpiSrc" alt="BPI QR" class="qr-preview d-block mb-1" />
                            <span class="text-success small"><i class="bi bi-check-circle me-1"></i>QR uploaded</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-secondary small mb-2"><i class="bi bi-image me-1"></i>No QR uploaded yet</div>
                    }
                    <input type="file" name="bpiQr" class="form-control"
                           accept="image/png,image/jpeg,image/webp"
                           onchange="previewQr(this,'bpiPreview')" />
                    <img id="bpiPreview" src="" class="qr-preview mt-2 d-none" alt="Preview" />
                    <div class="form-text text-secondary">PNG or JPG. The QR will be shown on the Donate page.</div>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-semibold">
                    <i class="bi bi-cloud-upload me-2"></i>Save QR Codes
                </button>
            </form>
        </div>

        <p class="text-secondary small text-center mt-3">
            <a href="/Home/Donate" target="_blank" class="nav-link d-inline-block">
                <i class="bi bi-box-arrow-up-right me-1"></i>Preview Donate page
            </a>
        </p>
    }
</div>

<script>
    function previewQr(input, previewId) {
        const preview = document.getElementById(previewId);
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => { preview.src = e.target.result; preview.classList.remove('d-none'); };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
</body>
</html>
