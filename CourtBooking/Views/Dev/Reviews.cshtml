@using CourtBooking.Models
@model List<Review>
@{
    Layout = null;
    ViewData["Title"] = "CourtBook — Review Moderation";

    var password   = ViewBag.Password as string ?? "";
    var errorMsg   = ViewBag.Error    as string;
    var isUnlocked = !string.IsNullOrEmpty(password);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body          { background: #0d1117; color: #e6edf3; }
        .dev-card     { background: #161b22; border: 1px solid #30363d; border-radius: 12px; }
        .form-control, .form-select {
            background: #0d1117; border-color: #30363d; color: #e6edf3;
        }
        .form-control:focus { background: #0d1117; border-color: #58a6ff;
                              color: #e6edf3; box-shadow: none; }
        .form-control::placeholder { color: #6e7681; }
        .nav-link { color: #58a6ff !important; font-size: .85rem; }
        .row-pending  { border-left: 4px solid #f59f00; }
        .row-featured { border-left: 4px solid #2da44e; background: rgba(45,164,78,.06); }
    </style>
</head>
<body>
<div class="container py-5" style="max-width: 820px;">

    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10
                    rounded-circle mb-3" style="width:64px;height:64px;">
            <i class="bi bi-chat-quote-fill text-warning fs-2"></i>
        </div>
        <h3 class="fw-bold mb-1">Review Moderation</h3>
        <p class="text-secondary small mb-0">Approve, feature, or delete facility-owner testimonials</p>
        <div class="mt-1">
            <a href="/Dev/Subscriptions" class="nav-link d-inline-block">Subscriptions</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Facilities" class="nav-link d-inline-block">Facilities</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/KeyGen" class="nav-link d-inline-block">Key Generator</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> @successMsg
        </div>
    }

    @if (!isUnlocked)
    {
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }
        <div class="dev-card p-4">
            <form method="post" asp-action="Reviews" asp-controller="Dev">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">
                        <i class="bi bi-shield-lock me-1"></i>Developer Password
                    </label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Enter developer password" autofocus required />
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark">
                    <i class="bi bi-unlock me-2"></i>Unlock
                </button>
            </form>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="dev-card p-4 text-center">
            <i class="bi bi-chat-square-text display-4 text-secondary opacity-50"></i>
            <h5 class="mt-3 text-secondary">No reviews submitted yet</h5>
        </div>
    }
    else
    {
        var pending   = Model.Count(r => !r.IsApproved);
        var featured  = Model.Count(r => r.IsFeatured);
        <p class="text-secondary small mb-3">
            <i class="bi bi-stack me-1"></i>@Model.Count total · @pending pending · @featured featured on homepage
        </p>

        @foreach (var r in Model)
        {
            var rowClass = r.IsFeatured ? "row-featured" : (!r.IsApproved ? "row-pending" : "");
            <div class="dev-card p-4 mb-3 @rowClass">
                <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
                    <div>
                        <h6 class="fw-bold mb-1">@r.OwnerName</h6>
                        <div class="text-secondary small">@r.FacilityName</div>
                        <div class="mt-1">
                            @for (int i = 0; i < r.Rating; i++)
                            {
                                <i class="bi bi-star-fill text-warning"></i>
                            }
                            @for (int i = r.Rating; i < 5; i++)
                            {
                                <i class="bi bi-star text-secondary"></i>
                            }
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="small text-secondary mb-1">
                            @r.SubmittedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                        </div>
                        <div class="d-flex gap-1 flex-wrap justify-content-end">
                            @if (r.IsFeatured)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-stars me-1"></i>Featured
                                </span>
                            }
                            else if (r.IsApproved)
                            {
                                <span class="badge bg-primary">
                                    <i class="bi bi-check-circle me-1"></i>Approved
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-hourglass-split me-1"></i>Pending
                                </span>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(r.Title))
                {
                    <div class="fw-semibold mb-1">"@r.Title"</div>
                }
                <p class="text-light small mb-3" style="white-space:pre-wrap;">@r.Body</p>

                <hr class="border-secondary my-3" />

                <div class="d-flex gap-2 flex-wrap align-items-center">
                    @if (!r.IsApproved)
                    {
                        <form asp-action="ApproveReview" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id"       value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-check-circle me-1"></i>Approve
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="UnapproveReview" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id"       value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary"
                                    onclick="return confirm('Unapprove this review? It will be hidden from the homepage.')">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Unapprove
                            </button>
                        </form>
                    }

                    @if (!r.IsFeatured)
                    {
                        <form asp-action="FeatureReview" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id"       value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="bi bi-stars me-1"></i>Feature on Homepage
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="UnfeatureReview" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id"       value="@r.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-star-half me-1"></i>Unfeature
                            </button>
                        </form>
                    }

                    <form asp-action="SetReviewOrder" method="post" class="d-flex align-items-center gap-1 d-inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="password" value="@password" />
                        <input type="hidden" name="id"       value="@r.Id" />
                        <label class="small text-secondary mb-0">Order:</label>
                        <input type="number" name="displayOrder" value="@r.DisplayOrder"
                               class="form-control form-control-sm" style="width:80px;" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Set</button>
                    </form>

                    <form asp-action="DeleteReview" method="post" class="d-inline ms-auto">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="password" value="@password" />
                        <input type="hidden" name="id"       value="@r.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Permanently delete this review?')">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>
</body>
</html>
