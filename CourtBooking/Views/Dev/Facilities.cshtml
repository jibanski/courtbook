@using CourtBooking.Models
@model List<CourtBooking.Controllers.DevController.FacilityAdminRow>
@{
    Layout = null;
    ViewData["Title"] = "CourtBook — Facility Management";

    var password   = ViewBag.Password as string ?? "";
    var errorMsg   = ViewBag.Error    as string;
    var isUnlocked = !string.IsNullOrEmpty(password);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body          { background: #0d1117; color: #e6edf3; }
        .dev-card     { background: #161b22; border: 1px solid #30363d; border-radius: 12px; }
        .form-control, .form-select {
            background: #0d1117; border-color: #30363d; color: #e6edf3;
        }
        .form-control:focus { background: #0d1117; border-color: #58a6ff;
                              color: #e6edf3; box-shadow: none; }
        .form-control::placeholder { color: #6e7681; }
        .nav-link { color: #58a6ff !important; font-size: .85rem; }
        .row-suspended { border-left: 4px solid #f59f00; }
        .row-locked    { border-left: 4px solid #dc3545; }
        .row-both      { border-left: 4px solid #dc3545; background: rgba(220,53,69,.06); }
    </style>
</head>
<body>
<div class="container py-5" style="max-width: 880px;">

    <!-- Header -->
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10
                    rounded-circle mb-3" style="width:64px;height:64px;">
            <i class="bi bi-shield-lock-fill text-danger fs-2"></i>
        </div>
        <h3 class="fw-bold mb-1">Facility Management</h3>
        <p class="text-secondary small mb-0">Suspend public pages or disable owner logins</p>
        <div class="mt-1">
            <a href="/Dev/Subscriptions" class="nav-link d-inline-block">Subscriptions</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Reviews" class="nav-link d-inline-block">Reviews</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/KeyGen" class="nav-link d-inline-block">Key Generator</a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/DonationQr" class="nav-link d-inline-block">Donation QR</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> @successMsg
        </div>
    }
    @if (TempData["Error"] is string errMsg)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-x-circle-fill"></i> @errMsg
        </div>
    }

    @if (!isUnlocked)
    {
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }
        <div class="dev-card p-4">
            <form method="post" asp-action="Facilities" asp-controller="Dev">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">
                        <i class="bi bi-shield-lock me-1"></i>Developer Password
                    </label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Enter developer password" autofocus required />
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark">
                    <i class="bi bi-unlock me-2"></i>Unlock
                </button>
            </form>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="dev-card p-4 text-center">
            <i class="bi bi-building display-4 text-secondary opacity-50"></i>
            <h5 class="mt-3 text-secondary">No facilities registered yet</h5>
        </div>
    }
    else
    {
        <p class="text-secondary small mb-3">
            <i class="bi bi-stack me-1"></i>@Model.Count facilit@(Model.Count == 1 ? "y" : "ies") registered
        </p>

        @foreach (var row in Model)
        {
            var f = row.Facility;
            var rowClass = (f.IsSuspended && row.IsLocked) ? "row-both"
                         : f.IsSuspended ? "row-suspended"
                         : row.IsLocked  ? "row-locked"
                         : "";

            <div class="dev-card p-4 mb-3 @rowClass">
                <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
                    <div>
                        <h5 class="fw-bold mb-1">@f.FacilityName</h5>
                        <div class="d-flex gap-2 flex-wrap small">
                            @if (f.IsSuspended)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-cone-striped me-1"></i>Page Suspended
                                </span>
                            }
                            @if (row.IsLocked)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-key-fill me-1"></i>Login Disabled
                                </span>
                            }
                            @if (!f.IsSuspended && !row.IsLocked)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>Active
                                </span>
                            }
                            @if (f.IsSubscribed)
                            {
                                <span class="badge bg-primary">
                                    <i class="bi bi-patch-check-fill me-1"></i>Pro
                                </span>
                            }
                            else if (f.IsTrialActive)
                            {
                                <span class="badge bg-info text-dark">Trial</span>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(f.Slug))
                    {
                        <a href="/sportshub/@f.Slug" target="_blank"
                           class="btn btn-sm btn-outline-secondary text-nowrap">
                            <i class="bi bi-box-arrow-up-right me-1"></i>/sportshub/@f.Slug
                        </a>
                    }
                </div>

                <div class="row g-2 small mb-3">
                    <div class="col-4 text-secondary">Owner</div>
                    <div class="col-8 text-light">
                        @row.OwnerName <span class="text-secondary">&lt;@row.OwnerEmail&gt;</span>
                    </div>

                    @if (f.IsSuspended && f.SuspendedAt.HasValue)
                    {
                        <div class="col-4 text-secondary">Suspended</div>
                        <div class="col-8 text-light">
                            @f.SuspendedAt.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            @if (!string.IsNullOrWhiteSpace(f.SuspendedReason))
                            {
                                <div class="text-secondary fst-italic">"@f.SuspendedReason"</div>
                            }
                        </div>
                    }

                    @if (row.IsLocked && row.LockoutEnd.HasValue)
                    {
                        <div class="col-4 text-secondary">Locked Until</div>
                        <div class="col-8 text-light">
                            @(row.LockoutEnd.Value.Year > 2100
                                ? "(indefinite)"
                                : row.LockoutEnd.Value.ToLocalTime().ToString("MMM d, yyyy"))
                        </div>
                    }
                </div>

                <hr class="border-secondary my-3" />

                <!-- Action row 1: page suspension -->
                <div class="row g-2 mb-2 align-items-center">
                    <div class="col-md-4 small text-secondary">
                        <i class="bi bi-eye-slash me-1"></i>Public Page
                    </div>
                    <div class="col-md-8">
                        @if (!f.IsSuspended)
                        {
                            <form asp-action="SuspendFacility" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="password" value="@password" />
                                <input type="hidden" name="id"       value="@f.Id" />
                                <input type="text"   name="reason"   class="form-control form-control-sm"
                                       placeholder="Reason (shown on banner to owner)" maxlength="500" />
                                <button type="submit" class="btn btn-sm btn-warning text-nowrap"
                                        onclick="return confirm('Suspend @Html.Raw(f.FacilityName)? Their /sportshub/@f.Slug page will be hidden.')">
                                    <i class="bi bi-cone-striped me-1"></i>Suspend
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="UnsuspendFacility" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="password" value="@password" />
                                <input type="hidden" name="id"       value="@f.Id" />
                                <button type="submit" class="btn btn-sm btn-success text-nowrap"
                                        onclick="return confirm('Reinstate @Html.Raw(f.FacilityName)? Their public page will be visible again.')">
                                    <i class="bi bi-check-circle me-1"></i>Reinstate
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <!-- Action row 2: owner login -->
                @if (f.OwnerId != null)
                {
                    <div class="row g-2 align-items-center mb-2">
                        <div class="col-md-4 small text-secondary">
                            <i class="bi bi-person-lock me-1"></i>Owner Login
                        </div>
                        <div class="col-md-8">
                            @if (!row.IsLocked)
                            {
                                <form asp-action="LockOwner" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="password" value="@password" />
                                    <input type="hidden" name="ownerId" value="@f.OwnerId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger text-nowrap"
                                            onclick="return confirm('Disable login for @row.OwnerEmail? They will not be able to sign in until you re-enable.')">
                                        <i class="bi bi-key-fill me-1"></i>Disable Login
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="UnlockOwner" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="password" value="@password" />
                                    <input type="hidden" name="ownerId" value="@f.OwnerId" />
                                    <button type="submit" class="btn btn-sm btn-success text-nowrap"
                                            onclick="return confirm('Re-enable login for @row.OwnerEmail?')">
                                        <i class="bi bi-unlock me-1"></i>Re-enable Login
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }

            </div>
        }
    }
</div>
</body>
</html>
