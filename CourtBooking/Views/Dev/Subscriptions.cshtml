@using CourtBooking.Models
@{
    Layout = null;
    ViewData["Title"] = "CourtBook — Subscription Approvals";

    var password       = ViewBag.Password       as string ?? "";
    var pendingList    = ViewBag.PendingList    as List<FacilitySettings> ?? new List<FacilitySettings>();
    var emailByOwnerId = ViewBag.EmailByOwnerId as Dictionary<string, string?> ?? new();
    var errorMsg       = ViewBag.Error          as string;
    var isUnlocked     = !string.IsNullOrEmpty(password);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body          { background: #0d1117; color: #e6edf3; }
        .dev-card     { background: #161b22; border: 1px solid #30363d; border-radius: 12px; }
        .proof-img    { max-width: 100%; max-height: 380px; border-radius: 8px;
                        border: 1px solid #30363d; object-fit: contain; }
        .form-control, .form-select {
            background: #0d1117; border-color: #30363d; color: #e6edf3;
        }
        .form-control:focus { background: #0d1117; border-color: #58a6ff;
                              color: #e6edf3; box-shadow: none; }
        .form-control::placeholder { color: #6e7681; }
        .nav-link { color: #58a6ff !important; font-size: .85rem; }
    </style>
</head>
<body>
<div class="container py-5" style="max-width: 640px;">

    <!-- Header -->
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10
                    rounded-circle mb-3" style="width:64px;height:64px;">
            <i class="bi bi-patch-check-fill text-warning fs-2"></i>
        </div>
        <h3 class="fw-bold mb-1">Subscription Approvals</h3>
        <p class="text-secondary small mb-0">Review and approve or reject pending subscription payments</p>
        <div class="mt-1">
            <a href="/Dev/KeyGen" class="nav-link d-inline-block">
                <i class="bi bi-key me-1"></i>Key Generator
            </a>
            <span class="text-secondary mx-1">·</span>
            <a href="/Dev/Facilities" class="nav-link d-inline-block">
                <i class="bi bi-shield-lock me-1"></i>Facilities
            </a>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> @successMsg
        </div>
    }
    @if (TempData["Error"] is string errMsg)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-x-circle-fill"></i> @errMsg
        </div>
    }

    @if (!isUnlocked)
    {
        <!-- Password gate -->
        @if (!string.IsNullOrEmpty(errorMsg))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMsg
            </div>
        }
        <div class="dev-card p-4">
            <form method="post" asp-action="Subscriptions" asp-controller="Dev">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">
                        <i class="bi bi-shield-lock me-1"></i>Developer Password
                    </label>
                    <input type="password" name="password" class="form-control"
                           placeholder="Enter developer password" autofocus required />
                </div>
                <button type="submit" class="btn btn-warning w-100 fw-semibold text-dark">
                    <i class="bi bi-unlock me-2"></i>Unlock
                </button>
            </form>
        </div>
    }
    else if (!pendingList.Any())
    {
        <div class="dev-card p-4 text-center">
            <i class="bi bi-inbox display-4 text-secondary opacity-50"></i>
            <h5 class="mt-3 text-secondary">No Pending Submissions</h5>
            <p class="text-secondary small mb-0">All payment proofs have been processed.</p>
        </div>
    }
    else
    {
        <p class="text-secondary small mb-3">
            <i class="bi bi-stack me-1"></i>@pendingList.Count submission@(pendingList.Count == 1 ? "" : "s") awaiting review
        </p>

        @foreach (var settings in pendingList)
        {
            var ownerEmail = (settings.OwnerId is not null && emailByOwnerId.TryGetValue(settings.OwnerId, out var e))
                ? e ?? "(no email)"
                : "(no owner)";
            var isRenewal  = settings.IsRenewalPending;

            <!-- Pending submission card -->
            <div class="dev-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">@settings.FacilityName</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-hourglass-split me-1"></i>Awaiting Approval
                            </span>
                            @if (isRenewal)
                            {
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-arrow-repeat me-1"></i>Renewal
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-primary">
                                    <i class="bi bi-stars me-1"></i>New
                                </span>
                            }
                        </div>
                    </div>
                    <span class="text-secondary small">
                        @settings.SubscriptionSubmittedAt?.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                    </span>
                </div>

                <hr class="border-secondary" />

                <!-- Details -->
                <div class="row g-2 mb-3 small">
                    <div class="col-5 text-secondary">Owner Email</div>
                    <div class="col-7 font-monospace text-light">@ownerEmail</div>

                    <div class="col-5 text-secondary">Plan</div>
                    <div class="col-7 text-capitalize text-light">
                        <span class="badge @(settings.SubscriptionPlan == "annual" ? "bg-success" : "bg-primary")">
                            @settings.SubscriptionPlan
                        </span>
                    </div>

                    <div class="col-5 text-secondary">Reference No.</div>
                    <div class="col-7 font-monospace text-light">
                        @(string.IsNullOrWhiteSpace(settings.SubscriptionPaymentRef) ? "—" : settings.SubscriptionPaymentRef)
                    </div>

                    @if (isRenewal && settings.EffectiveSubscriptionExpiry.HasValue)
                    {
                        <div class="col-5 text-secondary">Current Expiry</div>
                        <div class="col-7 text-light">
                            @settings.EffectiveSubscriptionExpiry.Value.ToLocalTime().ToString("MMM d, yyyy")
                            <span class="text-secondary">(extends from this date)</span>
                        </div>
                    }
                </div>

                <!-- Proof image -->
                @if (!string.IsNullOrWhiteSpace(settings.SubscriptionProofPath))
                {
                    <div class="mb-3 text-center">
                        <p class="text-secondary small mb-2">
                            <i class="bi bi-image me-1"></i>Payment Screenshot
                        </p>
                        <img src="@settings.SubscriptionProofPath" alt="Payment proof" class="proof-img" />
                        <div class="mt-2">
                            <a href="@settings.SubscriptionProofPath" target="_blank"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Open Full Size
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary small mb-3">
                        <i class="bi bi-exclamation-circle me-1"></i>No proof image was uploaded.
                    </div>
                }

                <hr class="border-secondary" />

                <!-- Approve / Reject -->
                <div class="row g-2">
                    <div class="col-8">
                        <form asp-action="ApproveSubscription" asp-controller="Dev" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id" value="@settings.Id" />
                            <button type="submit" class="btn btn-success w-100 fw-semibold"
                                    onclick="return confirm('Approve @(isRenewal ? "renewal" : "subscription") for @Html.Raw(settings.FacilityName)?')">
                                <i class="bi bi-check-circle-fill me-2"></i>Approve & @(isRenewal ? "Extend" : "Activate")
                            </button>
                        </form>
                    </div>
                    <div class="col-4">
                        <form asp-action="RejectSubscription" asp-controller="Dev" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="password" value="@password" />
                            <input type="hidden" name="id" value="@settings.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Reject and clear the submission for @Html.Raw(settings.FacilityName)?')">
                                <i class="bi bi-x-circle me-1"></i>Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }

</div>
</body>
</html>
