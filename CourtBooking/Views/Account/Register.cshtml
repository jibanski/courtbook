@model CourtBooking.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-sm-10 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-plus-fill display-5 text-primary"></i>
                        <h2 class="fw-bold mt-2">Create Account</h2>
                        <p class="text-muted">Join CourtBook to start booking courts</p>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-6">
                                <label asp-for="FirstName" class="form-label fw-semibold">First Name</label>
                                <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="LastName" class="form-label fw-semibold">Last Name</label>
                                <input asp-for="LastName" class="form-control" placeholder="Dela Cruz" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="juan@email.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="09XX XXX XXXX" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                                <input asp-for="Password" class="form-control" placeholder="Minimum 6 characters" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                                <input asp-for="ConfirmPassword" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input asp-for="AgreeToPrivacyPolicy" class="form-check-input" type="checkbox" required />
                                    <label asp-for="AgreeToPrivacyPolicy" class="form-check-label small">
                                        I agree to the <a asp-controller="Home" asp-action="Privacy" target="_blank">Privacy Policy</a>
                                    </label>
                                    <span asp-validation-for="AgreeToPrivacyPolicy" class="text-danger small d-block"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100 py-2">
                                    <i class="bi bi-person-check me-1"></i>Create Account
                                </button>
                            </div>
                        </div>
                    </form>

                    <hr />
                    <p class="text-center text-muted mb-0">
                        Already have an account? <a asp-controller="Account" asp-action="Login">Login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
