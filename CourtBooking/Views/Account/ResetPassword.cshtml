@model CourtBooking.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-sm-10 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock display-5 text-primary"></i>
                        <h2 class="fw-bold mt-2">Choose a new password</h2>
                        <p class="text-muted small mb-0">
                            For <strong>@Model.Email</strong>
                        </p>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">New Password</label>
                            <input asp-for="Password" class="form-control" autofocus
                                   placeholder="At least 6 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                            <input asp-for="ConfirmPassword" class="form-control"
                                   placeholder="Re-enter the password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="bi bi-check-circle me-1"></i>Reset Password
                        </button>
                    </form>

                    <hr />
                    <p class="text-center small mb-0 text-muted">
                        Need a fresh link? <a asp-action="ForgotPassword">Request another</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
