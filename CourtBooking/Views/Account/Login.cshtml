@model CourtBooking.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    var schemes = await Context.RequestServices
        .GetRequiredService<Microsoft.AspNetCore.Authentication.IAuthenticationSchemeProvider>()
        .GetAllSchemesAsync();
    bool hasGoogle   = schemes.Any(s => s.Name == "Google");
    bool hasFacebook = schemes.Any(s => s.Name == "Facebook");
    bool hasSocial   = hasGoogle || hasFacebook;
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-sm-10 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-3 mb-2"
                              style="width:52px;height:52px;background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.25);">
                            <i class="bi bi-lightning-charge-fill fs-4" style="color:var(--cb-lime);"></i>
                        </span>
                        <h2 class="fw-bold mt-1 mb-1">Welcome Back</h2>
                        <p style="color:var(--cb-text-3);font-size:.875rem;">Sign in to your CourtBook account</p>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
                            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
                            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    <div asp-validation-summary="All" class="alert alert-danger small"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    @* ── Social login buttons ── *@
                    @if (hasSocial)
                    {
                        <div class="d-flex flex-column gap-2 mb-3">
                            @if (hasGoogle)
                            {
                                <form asp-action="ExternalLogin" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="provider" value="Google" />
                                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                                    <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold"
                                            style="background:var(--cb-surface-2);border:1px solid var(--cb-border);color:var(--cb-text);font-size:.9rem;">
                                        <svg width="18" height="18" viewBox="0 0 48 48">
                                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                        </svg>
                                        Continue with Google
                                    </button>
                                </form>
                            }
                            @if (hasFacebook)
                            {
                                <form asp-action="ExternalLogin" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="provider" value="Facebook" />
                                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                                    <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold"
                                            style="background:#1877f2;border:none;color:#fff;font-size:.9rem;">
                                        <i class="bi bi-facebook fs-5"></i>
                                        Continue with Facebook
                                    </button>
                                </form>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <hr class="flex-grow-1 m-0" />
                            <span style="color:var(--cb-text-3);font-size:.78rem;white-space:nowrap;">or sign in with email</span>
                            <hr class="flex-grow-1 m-0" />
                        </div>
                    }

                    @* ── Email / password form ── *@
                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold small">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="juan@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold small">Password</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label small">Remember me</label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="small" style="color:var(--cb-lime);">
                                Forgot password?
                            </a>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </button>
                    </form>

                    <hr />
                    <p class="text-center mb-0" style="font-size:.875rem;color:var(--cb-text-3);">
                        Don't have an account?
                        <a asp-controller="Trial" asp-action="Start" asp-route-role="Customer"
                           style="color:var(--cb-lime);font-weight:600;">Register free</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
