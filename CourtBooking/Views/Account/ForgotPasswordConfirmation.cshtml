@{
    ViewData["Title"] = "Check Your Email";
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-sm-10 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle rounded-circle mb-3"
                         style="width:72px;height:72px;">
                        <i class="bi bi-envelope-check-fill text-success" style="font-size:2rem;"></i>
                    </div>

                    <h2 class="fw-bold mb-2">Check your email</h2>
                    <p class="text-muted mb-3">
                        If an account exists for the email you entered, we've sent a password reset link.
                        It's valid for <strong>1 hour</strong>.
                    </p>
                    <p class="text-muted small mb-4">
                        Be sure to check your spam folder if you don't see it within a few minutes.
                    </p>

                    <a asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
