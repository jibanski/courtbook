@model CourtBooking.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-sm-10 col-md-7 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-key display-5 text-primary"></i>
                        <h2 class="fw-bold mt-2">Forgot your password?</h2>
                        <p class="text-muted small mb-0">
                            Enter your email and we'll send you a link to reset it.
                        </p>
                    </div>

                    <div asp-validation-summary="All" class="alert alert-danger"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control" autofocus
                                   placeholder="you@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="bi bi-envelope me-1"></i>Send Reset Link
                        </button>
                    </form>

                    <hr />
                    <p class="text-center small mb-0">
                        <a asp-action="Login">
                            <i class="bi bi-arrow-left me-1"></i>Back to login
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
