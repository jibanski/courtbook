@model IEnumerable<CourtBooking.Models.Court>
@using CourtBooking.Models
@{
    var fs           = ViewBag.FacilitySettings as FacilitySettings;
    var sports       = ViewBag.Sports           as List<string> ?? new List<string>();
    var selectedSport= ViewBag.SelectedSport    as string;
    var slug         = ViewBag.Slug             as string;

    ViewData["Title"] = fs?.DisplayName ?? "Courts";

    string SportDefaultImage(string sport) => sport?.ToLower() switch {
        "tennis"       => "/images/sports/tennis.svg",
        "badminton"    => "/images/sports/badminton.svg",
        "basketball"   => "/images/sports/basketball.svg",
        "volleyball"   => "/images/sports/volleyball.svg",
        "football"     => "/images/sports/football.svg",
        "futsal"       => "/images/sports/futsal.svg",
        "swimming"     => "/images/sports/swimming.svg",
        "table tennis" => "/images/sports/table-tennis.svg",
        "billiards"    => "/images/sports/billiards.svg",
        "pickleball"   => "/images/sports/pickleball.svg",
        _              => "/images/sports/default.svg"
    };
}

<!-- Facility Hero -->
<div class="cb-facility-hero">
    <div class="container">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <!-- Logo / Icon -->
            @if (fs != null && !string.IsNullOrWhiteSpace(fs.BrandLogoUrl))
            {
                <img src="@fs.BrandLogoUrl" alt="@fs.DisplayName"
                     style="height:60px;object-fit:contain;border-radius:12px;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center rounded-3"
                     style="width:60px;height:60px;background:var(--cb-lime-dim);flex-shrink:0;border:1px solid rgba(163,255,18,0.25);">
                    <i class="bi bi-buildings-fill fs-3" style="color:var(--cb-lime);"></i>
                </div>
            }

            <!-- Facility Info -->
            <div class="flex-grow-1">
                <h1 class="mb-1 cb-fade-up" style="font-size:2rem;font-weight:800;letter-spacing:-0.03em;">
                    @(fs?.DisplayName ?? "Courts")
                </h1>
                @if (fs != null)
                {
                    <p class="mb-1 cb-fade-up-delay-1" style="color:var(--cb-text-2);font-size:.9rem;">
                        @fs.DisplayTagline
                    </p>
                    @if (!string.IsNullOrWhiteSpace(fs.Address))
                    {
                        <p class="mb-2 cb-fade-up-delay-1" style="color:var(--cb-text-3);font-size:.825rem;">
                            <i class="bi bi-geo-alt me-1" style="color:var(--cb-lime);"></i>@fs.Address
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(fs.FacebookUrl) || !string.IsNullOrWhiteSpace(fs.InstagramUrl))
                    {
                        <div class="d-flex gap-2 mt-2 cb-fade-up-delay-2">
                            @if (!string.IsNullOrWhiteSpace(fs.FacebookUrl))
                            {
                                <a href="@fs.FacebookUrl" target="_blank" rel="noopener"
                                   class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
                                   title="Facebook">
                                    <i class="bi bi-facebook" style="color:#1877f2;"></i>
                                    <span style="font-size:.78rem;">Facebook</span>
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(fs.InstagramUrl))
                            {
                                <a href="@fs.InstagramUrl" target="_blank" rel="noopener"
                                   class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
                                   title="Instagram">
                                    <i class="bi bi-instagram" style="color:#e1306c;"></i>
                                    <span style="font-size:.78rem;">Instagram</span>
                                </a>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="container py-4">

    <!-- Sport Filter Pills -->
    @if (sports.Any())
    {
        <div class="mb-4 cb-fade-up">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span style="color:var(--cb-text-3);font-size:.75rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;">Sport:</span>
                <a href="/sportshub/@slug"
                   class="btn btn-sm @(selectedSport == null ? "btn-primary" : "btn-outline-secondary")">All</a>
                @foreach (var sport in sports)
                {
                    <a href="/sportshub/@slug?sport=@Uri.EscapeDataString(sport)"
                       class="btn btn-sm @(selectedSport == sport ? "btn-primary" : "btn-outline-secondary")">@sport</a>
                }
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 cb-fade-up">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:72px;height:72px;background:var(--cb-surface-2);border:1px solid var(--cb-border);">
                <i class="bi bi-buildings display-5" style="color:var(--cb-text-3);"></i>
            </div>
            <h5 style="color:var(--cb-text-2);">No courts available yet</h5>
            <p style="color:var(--cb-text-3);font-size:.875rem;">Check back soon — courts are being added.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var court in Model)
            {
                <div class="col-sm-6 col-lg-4 cb-fade-up">
                    <div class="card h-100 court-card" style="overflow:hidden;">

                        <!-- Court image or sport default -->
                        <div class="position-relative" style="height:200px;overflow:hidden;">
                            <img src="@(!string.IsNullOrWhiteSpace(court.ImageUrl) ? court.ImageUrl : SportDefaultImage(court.SportType))"
                                 alt="@court.Name"
                                 style="width:100%;height:200px;object-fit:cover;transition:transform .4s ease;" />
                            @if (court.IsIndoor)
                            {
                                <span class="badge position-absolute top-0 end-0 m-2"
                                      style="background:var(--cb-lime-dim);color:var(--cb-lime);border:1px solid rgba(163,255,18,0.3);">Indoor</span>
                            }
                        </div>

                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="mb-0" style="font-weight:700;font-size:1.05rem;">@court.Name</h5>
                                <span class="badge" style="background:var(--cb-surface-3);color:var(--cb-text-2);font-size:.7rem;">
                                    @court.SportType
                                </span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(court.Description))
                            {
                                <p style="color:var(--cb-text-3);font-size:.825rem;margin-bottom:.75rem;line-height:1.5;">
                                    @court.Description
                                </p>
                            }
                            <div style="color:var(--cb-text-3);font-size:.8rem;">
                                <i class="bi bi-clock me-1" style="color:var(--cb-lime);"></i>
                                @court.OpeningHour:00 – @court.ClosingHour:00
                            </div>
                        </div>

                        <div class="card-footer p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <span style="font-size:1.4rem;font-weight:800;color:var(--cb-lime);letter-spacing:-0.02em;">
                                    ₱@court.PricePerHour.ToString("N0")
                                </span>
                                <span style="color:var(--cb-text-3);font-size:.8rem;font-weight:400;">/hr</span>
                            </div>
                            <a href="/sportshub/@slug/book/@court.Id" class="btn btn-primary btn-sm px-4">
                                <i class="bi bi-calendar-plus me-1"></i>Book Now
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    static string SportIcon(string sport) => sport?.ToLower() switch
    {
        "tennis"       => "bi-dribbble",
        "badminton"    => "bi-feather",
        "basketball"   => "bi-bullseye",
        "volleyball"   => "bi-circle-fill",
        "football"     => "bi-globe2",
        "futsal"       => "bi-lightning-charge-fill",
        "swimming"     => "bi-water",
        "table tennis" => "bi-record-circle",
        "billiards"    => "bi-circle",
        "pickleball"   => "bi-record2-fill",
        _              => "bi-trophy-fill"
    };
}
