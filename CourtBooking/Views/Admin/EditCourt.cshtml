@model CourtBooking.Models.Court
@{
    ViewData["Title"] = "Edit Court";
}

<div class="bg-dark text-white py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-1"><i class="bi bi-pencil me-2"></i>Edit Court</h1>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <!-- Court Details Form -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <form asp-action="EditCourt" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                        @await Html.PartialAsync("_CourtForm", Model)
                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Courts" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Schedule shortcut -->
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-bold"><i class="bi bi-calendar-week me-2 text-primary"></i>Time Slot Schedule</div>
                        <small class="text-muted">Define available booking slots per date for this court.</small>
                    </div>
                    <a asp-action="ManageSlots" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                        <i class="bi bi-calendar-week me-1"></i>Manage Schedule
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
function previewPhoto(input) {
    const preview = document.getElementById('photoPreview');
    if (input.files && input.files[0]) {
        preview.src = URL.createObjectURL(input.files[0]);
        preview.classList.remove('d-none');
    }
}
</script>
}
