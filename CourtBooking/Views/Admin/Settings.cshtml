@model CourtBooking.Models.FacilitySettings
@using CourtBooking.ViewModels
@{
    ViewData["Title"] = "Facility Settings";
}

<div class="bg-dark text-white py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-1"><i class="bi bi-gear-fill me-2"></i>Facility Settings</h1>
        <p class="mb-0 opacity-75">Configure payment details shown to customers</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <form asp-action="Settings" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- ── Custom Branding (Pro only) ──────────────────── -->
                <div class="card shadow-sm mb-4 @(Model.IsSubscribed ? "" : "opacity-75")">
                    <div class="card-header bg-white fw-bold d-flex align-items-center justify-content-between">
                        <span><i class="bi bi-palette me-2 text-primary"></i>Custom Branding</span>
                        @if (Model.IsSubscribed)
                        {
                            <span class="badge bg-success-subtle text-success">Pro Feature</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pro Only</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (!Model.IsSubscribed)
                        {
                            <div class="alert alert-secondary small mb-3 d-flex align-items-center gap-2">
                                <i class="bi bi-lock-fill fs-5 text-muted"></i>
                                <div>
                                    <strong>Unlock custom branding</strong> by upgrading to CourtBook Pro.
                                    Replace "CourtBook" with your facility name across the entire site.
                                    <a asp-controller="Subscription" asp-action="Upgrade" class="ms-1 fw-semibold">Upgrade Now →</a>
                                </div>
                            </div>
                        }

                        @if (Model.IsSubscribed)
                        {
                            <div class="mb-3">
                                <label asp-for="BrandName" class="form-label fw-semibold small">
                                    Site Name <span class="text-muted fw-normal">(replaces "CourtBook" everywhere)</span>
                                </label>
                                <input asp-for="BrandName" class="form-control"
                                       placeholder="e.g. Greenfield Sports Complex" />
                            </div>

                            <div class="mb-3">
                                <label asp-for="BrandTagline" class="form-label fw-semibold small">
                                    Tagline <span class="text-muted fw-normal">(shown in the footer)</span>
                                </label>
                                <input asp-for="BrandTagline" class="form-control"
                                       placeholder="e.g. Your premier sports destination" />
                            </div>

                            <div class="mb-0">
                                <label class="form-label fw-semibold small">
                                    Logo <span class="text-muted fw-normal">(shown in navbar instead of the text name)</span>
                                </label>
                                @if (!string.IsNullOrWhiteSpace(Model.BrandLogoUrl))
                                {
                                    <div class="mb-2 p-2 bg-primary d-inline-block rounded">
                                        <img src="@Model.BrandLogoUrl" alt="Current logo" id="logoPreview"
                                             style="height:36px;max-width:180px;object-fit:contain;" />
                                    </div>
                                    <br />
                                }
                                else
                                {
                                    <img src="" id="logoPreview" class="d-none mb-2"
                                         style="height:36px;max-width:180px;object-fit:contain;" />
                                }
                                <input type="file" name="logo" class="form-control"
                                       accept=".jpg,.jpeg,.png,.webp,.svg"
                                       onchange="previewLogo(this)" />
                                <div class="form-text">PNG, JPG, SVG. Recommended: transparent background, min 200px wide.</div>
                            </div>
                        }
                        else
                        {
                            <!-- Locked preview -->
                            <div class="pe-none opacity-50">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small">Site Name</label>
                                    <input type="text" class="form-control" disabled placeholder="e.g. Greenfield Sports Complex" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small">Tagline</label>
                                    <input type="text" class="form-control" disabled placeholder="e.g. Your premier sports destination" />
                                </div>
                                <div class="mb-0">
                                    <label class="form-label fw-semibold small">Logo</label>
                                    <input type="file" class="form-control" disabled />
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Shareable URL -->
                @if (!string.IsNullOrWhiteSpace(Model.Slug))
                {
                    var shareUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/f/{Model.Slug}";
                    <div class="card shadow-sm mb-4 border-primary-subtle">
                        <div class="card-header bg-primary-subtle fw-bold text-primary">
                            <i class="bi bi-link-45deg me-2"></i>Your Shareable Booking URL
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-2">
                                Share this link with your customers so they can browse and book your courts directly.
                            </p>
                            <div class="input-group">
                                <input type="text" id="shareUrl" class="form-control font-monospace small bg-light"
                                       value="@shareUrl" readonly />
                                <button class="btn btn-outline-primary" type="button" onclick="copyShareUrl()">
                                    <i class="bi bi-clipboard me-1"></i>Copy
                                </button>
                                <a href="/f/@Model.Slug" target="_blank" class="btn btn-primary">
                                    <i class="bi bi-box-arrow-up-right me-1"></i>Open
                                </a>
                            </div>
                            <div id="copySuccess" class="text-success small mt-1 d-none">
                                <i class="bi bi-check-circle me-1"></i>Copied to clipboard!
                            </div>
                        </div>
                    </div>
                }

                <!-- Facility Name -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-building me-2"></i>Facility Info
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="FacilityName" class="form-label fw-semibold">Facility Name</label>
                            <input asp-for="FacilityName" class="form-control" placeholder="e.g. City Sports Complex" />
                            <span asp-validation-for="FacilityName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold">Address</label>
                            <input asp-for="Address" class="form-control"
                                   placeholder="e.g. 123 Rizal St., Cebu City, 6000 Cebu" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                            <div class="form-text">Shown to customers on the booking and payment pages.</div>
                        </div>
                        <div class="mb-0">
                            <label asp-for="Slug" class="form-label fw-semibold">
                                URL Slug
                                <span class="fw-normal text-muted small">— the <code>/f/your-slug</code> part of your booking link</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text text-muted small">/f/</span>
                                <input asp-for="Slug" class="form-control font-monospace"
                                       placeholder="e.g. city-sports-complex"
                                       pattern="[a-z0-9\-]+" title="Lowercase letters, numbers, and hyphens only" />
                            </div>
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                            <div class="form-text">Lowercase letters, numbers, and hyphens only. Changing this will break existing shared links.</div>
                        </div>
                    </div>
                </div>

                <!-- GCash -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-phone me-2 text-primary"></i>GCash
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="GCashNumber" class="form-label fw-semibold">GCash Number</label>
                            <input asp-for="GCashNumber" class="form-control" placeholder="09XXXXXXXXX" />
                            <span asp-validation-for="GCashNumber" class="text-danger small"></span>
                        </div>
                        <div class="mb-0">
                            <label asp-for="GCashName" class="form-label fw-semibold">Account Name</label>
                            <input asp-for="GCashName" class="form-control" placeholder="Full name on GCash account" />
                            <span asp-validation-for="GCashName" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Maya -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-phone me-2 text-success"></i>Maya
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="MayaNumber" class="form-label fw-semibold">Maya Number</label>
                            <input asp-for="MayaNumber" class="form-control" placeholder="09XXXXXXXXX" />
                            <span asp-validation-for="MayaNumber" class="text-danger small"></span>
                        </div>
                        <div class="mb-0">
                            <label asp-for="MayaName" class="form-label fw-semibold">Account Name</label>
                            <input asp-for="MayaName" class="form-control" placeholder="Full name on Maya account" />
                            <span asp-validation-for="MayaName" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Social Media -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-share me-2 text-info"></i>Social Media
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            Add your social pages so customers can follow you. Links appear on your facility page.
                        </p>
                        <div class="mb-3">
                            <label asp-for="FacebookUrl" class="form-label fw-semibold">
                                <i class="bi bi-facebook text-primary me-1"></i>Facebook Page URL
                            </label>
                            <input asp-for="FacebookUrl" type="url" class="form-control"
                                   placeholder="https://facebook.com/your-page" />
                            <span asp-validation-for="FacebookUrl" class="text-danger small"></span>
                        </div>
                        <div class="mb-0">
                            <label asp-for="InstagramUrl" class="form-label fw-semibold">
                                <i class="bi bi-instagram text-danger me-1"></i>Instagram Profile URL
                            </label>
                            <input asp-for="InstagramUrl" type="url" class="form-control"
                                   placeholder="https://instagram.com/your-handle" />
                            <span asp-validation-for="InstagramUrl" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Payment Instructions -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-chat-text me-2"></i>Payment Instructions
                    </div>
                    <div class="card-body">
                        <textarea asp-for="PaymentInstructions" class="form-control" rows="3"
                                  placeholder="e.g. Please send the exact amount and include your booking reference in the notes."></textarea>
                        <span asp-validation-for="PaymentInstructions" class="text-danger small"></span>
                        <div class="form-text">Shown to customers on the payment page.</div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Settings
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>

            <!-- ── Subscription ──────────────────────────────────────── -->
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-white fw-bold d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-trophy-fill text-warning me-2"></i>Subscription</span>
                    @if (Model.IsSubscribed && Model.IsSubscriptionExpired)
                    {
                        <span class="badge bg-danger">Expired</span>
                    }
                    else if (Model.IsSubscribed && Model.IsSubscriptionExpiringSoon)
                    {
                        <span class="badge bg-warning text-dark">Expiring Soon</span>
                    }
                    else if (Model.IsSubscribed)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else if (Model.IsSubscriptionPending)
                    {
                        <span class="badge bg-warning text-dark">Pending Verification</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Free Trial</span>
                    }
                </div>
                <div class="card-body">

                    @if (Model.IsSubscribed)
                    {
                        var planLabel = string.Equals(Model.SubscriptionPlan, "annual", StringComparison.OrdinalIgnoreCase)
                            ? "Annual" : "Monthly";
                        var expiry    = Model.EffectiveSubscriptionExpiry;
                        var expired   = Model.IsSubscriptionExpired;
                        var expSoon   = Model.IsSubscriptionExpiringSoon;
                        var daysLeft  = Model.SubscriptionDaysRemaining;

                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="@(expired ? "bg-danger-subtle" : "bg-success-subtle") rounded-circle d-flex align-items-center justify-content-center"
                                 style="width:52px;height:52px;flex-shrink:0;">
                                <i class="bi @(expired ? "bi-x-circle-fill text-danger" : "bi-check-circle-fill text-success") fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-bold">
                                    CourtBook Pro — @(expired ? "Expired" : "Active")
                                </div>
                                <div class="text-muted small">@planLabel plan</div>
                            </div>
                        </div>

                        <div class="bg-light rounded-3 p-3 small mb-3">
                            <div class="row g-2">
                                <div class="col-5 text-muted">Plan</div>
                                <div class="col-7 fw-semibold">@planLabel</div>

                                <div class="col-5 text-muted">Activated on</div>
                                <div class="col-7 fw-semibold">
                                    @(Model.SubscriptionActivatedAt?.ToLocalTime().ToString("MMMM d, yyyy") ?? "—")
                                </div>

                                <div class="col-5 text-muted">Expires on</div>
                                <div class="col-7 fw-semibold @(expired ? "text-danger" : expSoon ? "text-warning" : "")">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @(expiry?.ToLocalTime().ToString("MMMM d, yyyy") ?? "—")
                                </div>

                                @if (expiry.HasValue)
                                {
                                    <div class="col-5 text-muted">Time remaining</div>
                                    <div class="col-7 fw-semibold @(expired ? "text-danger" : expSoon ? "text-warning" : "text-success")">
                                        @if (expired)
                                        {
                                            <i class="bi bi-exclamation-triangle me-1"></i><span>Expired</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-hourglass-split me-1"></i>
                                            <span>@daysLeft day@(daysLeft == 1 ? "" : "s") left</span>
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(Model.SubscriptionPaymentRef))
                                {
                                    <div class="col-5 text-muted">Reference #</div>
                                    <div class="col-7 fw-semibold font-monospace">@Model.SubscriptionPaymentRef</div>
                                }
                            </div>
                        </div>

                        @if (expired)
                        {
                            <div class="alert alert-danger small mb-3">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                <strong>Your subscription has expired.</strong>
                                Pro features may be locked. Renew now to restore full access.
                            </div>
                            <a asp-controller="Subscription" asp-action="Upgrade" class="btn btn-danger fw-semibold">
                                <i class="bi bi-arrow-repeat me-1"></i>Renew Subscription
                            </a>
                        }
                        else if (expSoon)
                        {
                            <div class="alert alert-warning small mb-3">
                                <i class="bi bi-bell-fill me-1"></i>
                                <strong>Renewal reminder:</strong>
                                Your subscription expires in @daysLeft day@(daysLeft == 1 ? "" : "s"). Renew early to avoid interruption.
                            </div>
                            <a asp-controller="Subscription" asp-action="Upgrade" class="btn btn-warning fw-semibold">
                                <i class="bi bi-arrow-up-circle me-1"></i>Renew Early
                            </a>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">
                                <i class="bi bi-shield-check me-1 text-success"></i>
                                Your subscription is active. All features are fully unlocked.
                            </p>
                        }
                    }
                    else if (Model.IsSubscriptionPending)
                    {
                        <div class="alert alert-warning small mb-3">
                            <i class="bi bi-hourglass-split me-2"></i>
                            <strong>Payment submitted</strong> — awaiting verification.
                            We'll email your activation key within 24 hours.
                        </div>
                        <div class="bg-light rounded-3 p-3 small mb-3">
                            <div class="row g-2">
                                <div class="col-5 text-muted">Plan</div>
                                <div class="col-7 fw-semibold text-capitalize">
                                    @(Model.SubscriptionPlan == "annual" ? "Annual" : "Monthly")
                                </div>
                                <div class="col-5 text-muted">Reference #</div>
                                <div class="col-7 fw-semibold">@Model.SubscriptionPaymentRef</div>
                                <div class="col-5 text-muted">Submitted</div>
                                <div class="col-7 fw-semibold">
                                    @Model.SubscriptionSubmittedAt?.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </div>
                            </div>
                        </div>
                        <a asp-controller="Subscription" asp-action="Pending" class="btn btn-outline-warning btn-sm me-2">
                            <i class="bi bi-clock me-1"></i>View Status
                        </a>
                        <a asp-controller="Subscription" asp-action="Upgrade" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-repeat me-1"></i>Resubmit
                        </a>
                    }
                    else
                    {
                        <p class="text-muted small mb-3">
                            You are currently on a <strong>Free Trial</strong>.
                            Upgrade to CourtBook Pro for uninterrupted access.
                        </p>
                        <a asp-controller="Subscription" asp-action="Upgrade"
                           class="btn btn-primary fw-semibold mb-4">
                            <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Pro
                        </a>
                    }

                    @if (!Model.IsSubscribed)
                    {
                        <hr />
                        <h6 class="fw-bold mb-2"><i class="bi bi-key me-2"></i>Enter Activation Key</h6>
                        <p class="text-muted small mb-3">
                            Received your activation key by email? Enter it below to instantly unlock CourtBook Pro.
                        </p>
                        <form asp-controller="Subscription" asp-action="Activate" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="text" name="Key" class="form-control form-control-sm font-monospace"
                                   placeholder="e.g. COURTBOOK-ACTIVATE-XXXX"
                                   style="max-width:300px;" required />
                            <button type="submit" class="btn btn-success btn-sm fw-semibold text-nowrap">
                                <i class="bi bi-unlock me-1"></i>Activate
                            </button>
                        </form>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewLogo(input) {
            const preview = document.getElementById('logoPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function copyShareUrl() {
            const input = document.getElementById('shareUrl');
            navigator.clipboard.writeText(input.value).then(() => {
                const msg = document.getElementById('copySuccess');
                msg.classList.remove('d-none');
                setTimeout(() => msg.classList.add('d-none'), 2500);
            });
        }
    </script>
}
