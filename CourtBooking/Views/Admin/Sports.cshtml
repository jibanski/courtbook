@model IEnumerable<CourtBooking.Models.Sport>
@{
    ViewData["Title"] = "Manage Sports";
}

<div class="bg-dark text-white py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-1"><i class="bi bi-trophy me-2"></i>Manage Sports</h1>
        <p class="mb-0 opacity-75">Add, edit, or remove sport types available for courts</p>
    </div>
</div>

<div class="container">
    <div class="row g-4">

        <!-- Add Sport Form -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Sport
                </div>
                <div class="card-body">
                    <form asp-action="CreateSport" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sport Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" placeholder="e.g. Pickleball" maxlength="50" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="Description" class="form-control" rows="2" placeholder="Short description (optional)" maxlength="100"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Display Order</label>
                            <input type="number" name="DisplayOrder" class="form-control" value="0" min="0" />
                            <div class="form-text">Lower number = appears first in dropdowns.</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-circle me-1"></i>Add Sport
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sports Table -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold">@Model.Count() sport(s)</span>
                </div>
                @if (!Model.Any())
                {
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-trophy display-4 opacity-25 d-block mb-3"></i>
                        No sports added yet.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Order</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sport in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@sport.Name</td>
                                        <td class="text-muted small">@(sport.Description ?? "—")</td>
                                        <td>@sport.DisplayOrder</td>
                                        <td>
                                            <span class="badge @(sport.IsActive ? "bg-success" : "bg-secondary")">
                                                @(sport.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <!-- Edit inline via modal -->
                                                <button class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editModal"
                                                        data-id="@sport.Id"
                                                        data-name="@sport.Name"
                                                        data-description="@sport.Description"
                                                        data-order="@sport.DisplayOrder">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form asp-action="ToggleSport" asp-route-id="@sport.Id" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm @(sport.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                            title="@(sport.IsActive ? "Deactivate" : "Activate")">
                                                        <i class="bi bi-toggle-@(sport.IsActive ? "on" : "off")"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="DeleteSport" asp-route-id="@sport.Id" method="post"
                                                      onsubmit="return confirm('Delete sport \'@sport.Name\'? This cannot be undone.')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditSport" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Edit Sport</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sport Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" id="editName" class="form-control" maxlength="50" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" id="editDescription" class="form-control" rows="2" maxlength="100"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Display Order</label>
                        <input type="number" name="displayOrder" id="editOrder" class="form-control" min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        document.getElementById('editId').value          = btn.dataset.id;
        document.getElementById('editName').value        = btn.dataset.name;
        document.getElementById('editDescription').value = btn.dataset.description ?? '';
        document.getElementById('editOrder').value       = btn.dataset.order;
    });
</script>
}
