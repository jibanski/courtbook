@model List<CourtBooking.Models.CourtTimeSlot>
@{
    ViewData["Title"] = "Manage Schedule";
    var court    = ViewBag.Court as CourtBooking.Models.Court;
    var selDate  = (DateOnly)ViewBag.Date;
    var prevDate = selDate.AddDays(-1);
    var nextDate = selDate.AddDays(1);
    var today    = DateOnly.FromDateTime(DateTime.Today);
}

<div class="bg-dark text-white py-4 mb-4">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-action="Courts" class="text-white-50">Courts</a></li>
                <li class="breadcrumb-item"><a asp-action="EditCourt" asp-route-id="@court!.Id" class="text-white-50">@court.Name</a></li>
                <li class="breadcrumb-item active text-white">Schedule</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-1"><i class="bi bi-calendar-week me-2"></i>@court!.Name — Schedule</h1>
        <p class="mb-0 opacity-75">Define bookable time slots per date</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <!-- Date Navigator -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between gap-2">
                        <a asp-action="ManageSlots" asp-route-id="@court.Id" asp-route-date="@prevDate.ToString("yyyy-MM-dd")"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-chevron-left"></i>
                        </a>

                        <form method="get" class="flex-fill">
                            <input type="hidden" name="id" value="@court.Id" />
                            <div class="input-group input-group-sm">
                                <input type="date" name="date" class="form-control text-center fw-semibold"
                                       value="@selDate.ToString("yyyy-MM-dd")"
                                       onchange="this.form.submit()" />
                                @if (selDate != today)
                                {
                                    <a asp-action="ManageSlots" asp-route-id="@court.Id" asp-route-date="@today.ToString("yyyy-MM-dd")"
                                       class="btn btn-outline-primary btn-sm">Today</a>
                                }
                            </div>
                        </form>

                        <a asp-action="ManageSlots" asp-route-id="@court.Id" asp-route-date="@nextDate.ToString("yyyy-MM-dd")"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                    <div class="text-center text-muted small mt-2">
                        <strong>@selDate.ToString("dddd, MMMM d, yyyy")</strong>
                    </div>
                </div>
            </div>

            <!-- Slots for selected date -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-clock me-2 text-primary"></i>Slots for @selDate.ToString("MMM d")</span>
                    <span class="badge bg-@(Model.Any(s => s.IsActive) ? "success" : (Model.Any() ? "warning" : "secondary"))">
                        @Model.Count(s => s.IsActive) active
                    </span>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            @foreach (var slot in Model)
                            {
                                decimal price = court.PricePerHour * slot.DurationHours;
                                <div class="d-flex align-items-center gap-1">
                                    <span class="badge @(slot.IsActive ? "bg-success" : "bg-secondary") fs-6 px-3 py-2">
                                        @slot.TimeLabel
                                        <span class="ms-1 text-white-50 small">₱@price.ToString("N0")</span>
                                    </span>
                                    <form asp-action="ToggleCourtSlot" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@slot.Id" />
                                        <input type="hidden" name="courtId" value="@court.Id" />
                                        <input type="hidden" name="slotDate" value="@selDate.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="btn btn-sm @(slot.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(slot.IsActive ? "Disable" : "Enable")">
                                            <i class="bi @(slot.IsActive ? "bi-pause-fill" : "bi-play-fill")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="DeleteCourtSlot" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this slot?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@slot.Id" />
                                        <input type="hidden" name="courtId" value="@court.Id" />
                                        <input type="hidden" name="slotDate" value="@selDate.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-4">
                            <i class="bi bi-info-circle me-1"></i>No slots defined for this date — customers will see the full hourly grid.
                        </p>
                    }

                    <!-- Add Slot -->
                    <form asp-action="AddCourtSlot" method="post" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courtId" value="@court.Id" />
                        <input type="hidden" name="slotDate" value="@selDate.ToString("yyyy-MM-dd")" />
                        <div class="col-5">
                            <label class="form-label small fw-semibold mb-1">Start</label>
                            <select name="startHour" class="form-select form-select-sm">
                                @for (int h = court.OpeningHour; h < court.ClosingHour; h++)
                                {
                                    <option value="@h">@h.ToString("D2"):00</option>
                                }
                            </select>
                        </div>
                        <div class="col-5">
                            <label class="form-label small fw-semibold mb-1">End</label>
                            <select name="endHour" class="form-select form-select-sm">
                                @for (int h = court.OpeningHour + 1; h <= court.ClosingHour; h++)
                                {
                                    <option value="@h" selected="@(h == court.OpeningHour + 2)">@h.ToString("D2"):00</option>
                                }
                            </select>
                        </div>
                        <div class="col-2">
                            <button type="submit" class="btn btn-primary btn-sm w-100" title="Add slot">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        <div class="col-12">
                            <small class="text-muted">
                                Rate: ₱@court.PricePerHour.ToString("N0")/hr &bull;
                                Hours: @court.OpeningHour:00–@court.ClosingHour:00
                            </small>
                        </div>
                    </form>
                </div>
            </div>

            <a asp-action="EditCourt" asp-route-id="@court.Id" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Court
            </a>

        </div>
    </div>
</div>
