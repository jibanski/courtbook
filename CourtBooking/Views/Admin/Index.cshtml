@model IEnumerable<CourtBooking.Models.Booking>
@{
    ViewData["Title"] = "Dashboard";
    var fs = ViewBag.FacilitySettings as CourtBooking.Models.FacilitySettings;
}

<!-- Page Header -->
<div class="cb-page-header">
    <div class="container">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="cb-fade-up">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge" style="background:var(--cb-lime-dim);color:var(--cb-lime);font-size:.7rem;letter-spacing:.08em;">
                        <i class="bi bi-circle-fill me-1" style="font-size:.45rem;vertical-align:1px;"></i>LIVE
                    </span>
                </div>
                <h1 class="mb-1" style="font-size:1.75rem;">Dashboard</h1>
                <p style="color:var(--cb-text-2);font-size:.9rem;margin:0;">
                    @(fs?.DisplayName ?? "Your Facility") &mdash; @DateTime.Now.ToString("dddd, MMMM d, yyyy")
                </p>
            </div>
            <div class="d-flex gap-2 flex-wrap cb-fade-up-delay-1">
                <a asp-action="CreateCourt" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg me-1"></i>Add Court
                </a>
                <a asp-action="Bookings" asp-route-awaitingConfirmation="true" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-hourglass-split me-1"></i>Review Payments
                    @if ((int)ViewBag.AwaitingPayment > 0)
                    {
                        <span class="badge ms-1" style="background:var(--cb-lime);color:#071827;">@ViewBag.AwaitingPayment</span>
                    }
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">

    @* ── Setup Checklist (hidden once all REQUIRED steps are done & user dismisses) ── *@
    @{
        var setupSteps        = ViewBag.SetupSteps        as System.Collections.IEnumerable;
        var setupRequiredDone = (bool)(ViewBag.SetupRequiredDone ?? false);
        var setupDoneCount    = (int)(ViewBag.SetupDoneCount  ?? 0);
        var setupTotalCount   = (int)(ViewBag.SetupTotalCount ?? 0);
        var setupPct          = setupTotalCount > 0 ? (int)Math.Round(setupDoneCount * 100.0 / setupTotalCount) : 0;
    }
    @if (setupSteps is not null)
    {
        <div id="setupChecklist" class="cb-fade-up mb-4 @(setupRequiredDone ? "d-none" : "")">
            <div class="card border-0 shadow-sm" style="border-left:4px solid var(--cb-lime)!important;">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
                        <div>
                            <h5 class="mb-1" style="font-weight:700;">
                                <i class="bi bi-rocket-takeoff me-2" style="color:var(--cb-lime);"></i>Get your facility ready
                            </h5>
                            <p class="mb-0 text-muted small">
                                Finish these steps so customers can find and book your courts.
                            </p>
                        </div>
                        <div class="text-end">
                            <span class="badge rounded-pill" style="background:var(--cb-lime-dim);color:var(--cb-lime);font-size:.8rem;">
                                @setupDoneCount / @setupTotalCount complete
                            </span>
                        </div>
                    </div>

                    <div class="progress mb-3" style="height:6px;background:rgba(0,0,0,0.06);">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width:@(setupPct)%;background:var(--cb-lime);"
                             aria-valuenow="@setupPct" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>

                    <ul class="list-unstyled mb-0">
                        @foreach (dynamic step in setupSteps)
                        {
                            <li class="d-flex align-items-center justify-content-between py-2 border-bottom">
                                <div class="d-flex align-items-center gap-3 flex-grow-1" style="min-width:0;">
                                    @if ((bool)step.Done)
                                    {
                                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                              style="width:28px;height:28px;background:#198754;color:#fff;flex-shrink:0;">
                                            <i class="bi bi-check-lg"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                              style="width:28px;height:28px;background:#f1f3f5;color:#6c757d;flex-shrink:0;">
                                            <i class="bi @step.Icon"></i>
                                        </span>
                                    }
                                    <div style="min-width:0;">
                                        <div class="@((bool)step.Done ? "text-muted text-decoration-line-through" : "fw-semibold")">
                                            @step.Title
                                            @if (!(bool)step.Required)
                                            {
                                                <span class="badge bg-light text-secondary ms-1" style="font-size:.65rem;font-weight:500;">optional</span>
                                            }
                                        </div>
                                        <div class="small text-muted text-truncate">@step.Hint</div>
                                    </div>
                                </div>
                                @if (!(bool)step.Done)
                                {
                                    <a href="@step.Url" class="btn btn-sm btn-outline-primary ms-2 flex-shrink-0">
                                        @step.Cta <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }

    <!-- ── Stats Grid ──────────────────────────────────────────────────── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3 cb-fade-up">
            <div class="cb-stat-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="cb-stat-icon cb-bg-lime-dim">
                        <i class="bi bi-calendar-check" style="color:var(--cb-lime);"></i>
                    </div>
                    <i class="bi bi-arrow-up-right" style="color:var(--cb-lime);font-size:.8rem;"></i>
                </div>
                <div class="cb-stat-value">@ViewBag.TotalBookings</div>
                <div class="cb-stat-label">Total Bookings</div>
            </div>
        </div>
        <div class="col-6 col-lg-3 cb-fade-up-delay-1">
            <div class="cb-stat-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="cb-stat-icon cb-bg-blue-dim">
                        <i class="bi bi-calendar-day" style="color:var(--cb-blue);"></i>
                    </div>
                    <i class="bi bi-arrow-up-right" style="color:var(--cb-blue);font-size:.8rem;"></i>
                </div>
                <div class="cb-stat-value">@ViewBag.TodayBookings</div>
                <div class="cb-stat-label">Today's Bookings</div>
            </div>
        </div>
        <div class="col-6 col-lg-3 cb-fade-up-delay-2">
            <div class="cb-stat-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="cb-stat-icon" style="background:rgba(163,255,18,0.1);">
                        <i class="bi bi-cash-coin" style="color:var(--cb-lime);"></i>
                    </div>
                    <i class="bi bi-arrow-up-right" style="color:var(--cb-lime);font-size:.8rem;"></i>
                </div>
                <div class="cb-stat-value" style="font-size:1.5rem;">₱@(((decimal)ViewBag.TotalRevenue).ToString("N0"))</div>
                <div class="cb-stat-label">Total Revenue</div>
            </div>
        </div>
        <div class="col-6 col-lg-3 cb-fade-up-delay-3">
            <div class="cb-stat-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="cb-stat-icon cb-bg-blue-dim">
                        <i class="bi bi-buildings" style="color:var(--cb-blue);"></i>
                    </div>
                    <i class="bi bi-arrow-up-right" style="color:var(--cb-blue);font-size:.8rem;"></i>
                </div>
                <div class="cb-stat-value">@ViewBag.ActiveCourts</div>
                <div class="cb-stat-label">Active Courts</div>
            </div>
        </div>

        @if ((int)ViewBag.AwaitingPayment > 0)
        {
            <div class="col-12 cb-fade-up">
                <a asp-action="Bookings" asp-route-awaitingConfirmation="true" class="text-decoration-none d-block">
                    <div class="cb-stat-card cb-card-glow-red" style="border-color:rgba(239,68,68,0.35)!important;background:rgba(239,68,68,0.06)!important;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3">
                                <div class="cb-stat-icon" style="background:rgba(239,68,68,0.15);">
                                    <i class="bi bi-hourglass-split text-danger"></i>
                                </div>
                                <div>
                                    <div class="cb-stat-value" style="font-size:1.5rem;color:#f87171;">@ViewBag.AwaitingPayment</div>
                                    <div class="cb-stat-label">Payments Awaiting Confirmation — action required</div>
                                </div>
                            </div>
                            <span class="btn btn-danger btn-sm">
                                <i class="bi bi-arrow-right me-1"></i>Review
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <!-- ── Quick Actions ───────────────────────────────────────────────── -->
    <div class="mb-4 cb-fade-up">
        <p class="cb-stat-label mb-2">QUICK ACTIONS</p>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Courts" class="cb-quick-action"><i class="bi bi-buildings"></i>Manage Courts</a>
            <a asp-action="Bookings" class="cb-quick-action"><i class="bi bi-calendar3"></i>All Bookings</a>
            <a asp-action="Sports" class="cb-quick-action"><i class="bi bi-trophy"></i>Sports</a>
            <a asp-action="Settings" class="cb-quick-action"><i class="bi bi-sliders"></i>Settings</a>
            @if ((int)ViewBag.AwaitingPayment > 0)
            {
                <a asp-action="Bookings" asp-route-awaitingConfirmation="true" class="cb-quick-action danger">
                    <i class="bi bi-hourglass-split"></i>Confirm Payments
                    <span class="badge" style="background:#ef4444;color:#fff;border-radius:4px;">@ViewBag.AwaitingPayment</span>
                </a>
            }
        </div>
    </div>

    <!-- ── Recent Bookings ─────────────────────────────────────────────── -->
    <div class="card cb-fade-up">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0" style="font-size:1rem;font-weight:700;">
                    <i class="bi bi-clock-history me-2" style="color:var(--cb-lime);"></i>Recent Bookings
                </h5>
            </div>
            <a asp-action="Bookings" class="btn btn-outline-secondary btn-sm">View All</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Court</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:var(--cb-text-3);">
                                <i class="bi bi-calendar-x display-6 d-block mb-2 opacity-50"></i>
                                No bookings yet. Share your facility link to get started.
                            </td>
                        </tr>
                    }
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                          style="width:32px;height:32px;background:var(--cb-lime-dim);color:var(--cb-lime);font-weight:700;font-size:.8rem;flex-shrink:0;">
                                        @(b.User.FullName?.Substring(0,1).ToUpper() ?? "?")
                                    </span>
                                    <div>
                                        <div class="fw-semibold" style="font-size:.875rem;">@b.User.FullName</div>
                                        <div style="font-size:.75rem;color:var(--cb-text-3);">@b.User.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:.875rem;font-weight:500;">@b.Court.Name</div>
                                <span class="badge bg-secondary mt-1">@b.Court.SportType</span>
                            </td>
                            <td style="font-size:.875rem;color:var(--cb-text-2);">@b.BookingDate.ToString("MMM d, yyyy")</td>
                            <td style="font-size:.8rem;color:var(--cb-text-2);white-space:nowrap;">@b.StartTime.ToString("hh:mm tt") – @b.EndTime.ToString("hh:mm tt")</td>
                            <td style="font-weight:700;color:var(--cb-lime);">₱@b.TotalPrice.ToString("N0")</td>
                            <td>
                                @{
                                    var (badgeCls, badgeText) = b.Status switch {
                                        CourtBooking.Models.BookingStatus.Confirmed => ("bg-success-subtle", "Confirmed"),
                                        CourtBooking.Models.BookingStatus.Cancelled => ("bg-danger-subtle",  "Cancelled"),
                                        CourtBooking.Models.BookingStatus.Completed => ("bg-secondary",      "Completed"),
                                        _ => ("bg-warning-subtle", "Pending")
                                    };
                                }
                                <span class="badge @badgeCls">@badgeText</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Donation nudge — subtle -->
    <div class="text-center py-4" id="donationNudge">
        <p style="color:var(--cb-text-3);font-size:.825rem;margin-bottom:.35rem;">
            <i class="bi bi-heart-fill text-danger me-1"></i>
            CourtBook is free. If it's been helpful,
            <a asp-controller="Home" asp-action="Donate" style="color:var(--cb-lime);text-decoration:none;font-weight:600;">consider supporting us</a>
            — entirely optional. 🙏
        </p>
        <button class="btn btn-link btn-sm p-0" style="color:var(--cb-text-3);font-size:.75rem;text-decoration:none;"
                onclick="document.getElementById('donationNudge').style.display='none';localStorage.setItem('donationNudgeHidden','1');">
            Don't show again
        </button>
    </div>
    <script>
        if (localStorage.getItem('donationNudgeHidden') === '1') {
            document.getElementById('donationNudge').style.display = 'none';
        }
    </script>
</div>
