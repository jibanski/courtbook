@model CourtBooking.Models.Booking
@{
    ViewData["Title"] = "Payment Successful";
    bool isPaid = Model.PaymentStatus == CourtBooking.Models.PaymentStatus.Paid;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            @if (isPaid)
            {
                <div class="mb-4" style="font-size:4rem;">✅</div>
                <h1 class="fw-bold mb-2" style="color:#4ade80;">Payment Successful!</h1>
                <p style="color:var(--cb-text-2);font-size:1rem;">
                    Your booking has been <strong>confirmed</strong>. See you on the court!
                </p>
            }
            else
            {
                <div class="mb-4" style="font-size:4rem;">⏳</div>
                <h1 class="fw-bold mb-2" style="color:var(--cb-lime);">Payment Processing</h1>
                <p style="color:var(--cb-text-2);font-size:1rem;">
                    Your payment is being processed. Your booking will be confirmed shortly.
                </p>
            }

            <div class="card my-4 text-start">
                <div class="card-body">
                    <h6 class="fw-bold mb-3" style="color:var(--cb-text-2);">Booking Summary</h6>
                    <div class="row g-2" style="font-size:.9rem;">
                        <div class="col-5 text-muted">Court</div>
                        <div class="col-7 fw-semibold">@Model.Court?.Name</div>
                        <div class="col-5 text-muted">Date</div>
                        <div class="col-7 fw-semibold">@Model.BookingDate.ToString("MMMM d, yyyy")</div>
                        <div class="col-5 text-muted">Time</div>
                        <div class="col-7 fw-semibold">@Model.StartTime.ToString("hh:mm tt") – @Model.EndTime.ToString("hh:mm tt")</div>
                        <div class="col-5 text-muted">Amount Paid</div>
                        <div class="col-7 fw-bold" style="color:#4ade80;">₱@Model.TotalPrice.ToString("N0")</div>
                        <div class="col-5 text-muted">Reference</div>
                        <div class="col-7" style="font-size:.8rem;word-break:break-all;">@Model.PaymentReference</div>
                    </div>
                </div>
            </div>

            <a asp-action="My" class="btn btn-lg fw-bold" style="background:var(--cb-lime);color:#000;">
                <i class="bi bi-calendar-check me-2"></i>View My Bookings
            </a>

        </div>
    </div>
</div>
