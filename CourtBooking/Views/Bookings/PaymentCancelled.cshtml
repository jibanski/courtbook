@model CourtBooking.Models.Booking
@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            <div class="mb-4" style="font-size:4rem;">↩️</div>
            <h1 class="fw-bold mb-2" style="color:var(--cb-text-2);">Payment Cancelled</h1>
            <p style="color:var(--cb-text-3);font-size:1rem;">
                No charge was made. Your booking is still pending — you can complete payment anytime.
            </p>

            <div class="card my-4 text-start">
                <div class="card-body">
                    <h6 class="fw-bold mb-3" style="color:var(--cb-text-2);">Booking Details</h6>
                    <div class="row g-2" style="font-size:.9rem;">
                        <div class="col-5 text-muted">Court</div>
                        <div class="col-7 fw-semibold">@Model.Court?.Name</div>
                        <div class="col-5 text-muted">Date</div>
                        <div class="col-7 fw-semibold">@Model.BookingDate.ToString("MMMM d, yyyy")</div>
                        <div class="col-5 text-muted">Time</div>
                        <div class="col-7 fw-semibold">@Model.StartTime.ToString("hh:mm tt") – @Model.EndTime.ToString("hh:mm tt")</div>
                        <div class="col-5 text-muted">Amount Due</div>
                        <div class="col-7 fw-bold">₱@Model.TotalPrice.ToString("N0")</div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-action="Pay" asp-route-id="@Model.Id"
                   class="btn btn-lg fw-bold" style="background:var(--cb-lime);color:#000;">
                    <i class="bi bi-arrow-repeat me-2"></i>Try Payment Again
                </a>
                <a asp-action="My" class="btn btn-lg btn-outline-secondary">
                    <i class="bi bi-calendar me-2"></i>My Bookings
                </a>
            </div>

        </div>
    </div>
</div>
