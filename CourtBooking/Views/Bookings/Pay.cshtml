@model CourtBooking.Models.Booking
@{
    ViewData["Title"] = "Complete Payment";
    var settings    = ViewBag.Settings as CourtBooking.Models.FacilitySettings ?? new CourtBooking.Models.FacilitySettings();
    bool hasGCash      = !string.IsNullOrWhiteSpace(settings.GCashNumber);
    bool hasMaya       = !string.IsNullOrWhiteSpace(settings.MayaNumber);
    bool hasGCashQr    = !string.IsNullOrWhiteSpace(settings.GCashQrCodePath);
    bool hasMayaQr     = !string.IsNullOrWhiteSpace(settings.MayaQrCodePath);
    bool hasInstantPay = ViewBag.HasCardPay is true; // PayMongo configured
    // Manual e-wallet section is only shown as a fallback when the facility has
    // no instant gateway configured (per platform policy).
    bool showManualPay = !hasInstantPay && (hasGCash || hasMaya);

    var enabledMethods = settings.EnabledPayMongoMethods;
    bool m(string k) => enabledMethods.Contains(k);
}

<div class="cb-page-header">
    <div class="container">
        <div class="cb-fade-up">
            <h1 class="mb-1" style="font-size:1.75rem;">
                <i class="bi bi-credit-card me-2" style="color:var(--cb-lime);"></i>Complete Your Payment
            </h1>
            <p style="color:var(--cb-text-2);font-size:.9rem;margin:0;">Booking #@Model.Id — @Model.Court.Name</p>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <!-- Booking Summary -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-bold">
                    <i class="bi bi-receipt me-2 text-primary"></i>Booking Summary
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @if (!string.IsNullOrWhiteSpace(settings.FacilityName) && settings.FacilityName != "CourtBook")
                        {
                            <div class="col-6 text-muted small">Facility</div>
                            <div class="col-6 fw-semibold">
                                <i class="bi bi-buildings me-1 text-primary"></i>@settings.FacilityName
                            </div>
                            @if (!string.IsNullOrWhiteSpace(settings.Address))
                            {
                                <div class="col-6 text-muted small">Address</div>
                                <div class="col-6 fw-semibold small">
                                    <i class="bi bi-geo-alt me-1 text-muted"></i><a href="https://maps.google.com/?q=@Uri.EscapeDataString(settings.Address)" target="_blank" rel="noopener noreferrer" class="text-dark">@settings.Address</a>
                                </div>
                            }
                        }
                        <div class="col-6 text-muted small">Court</div>
                        <div class="col-6 fw-semibold">@Model.Court.Name (@Model.Court.SportType)</div>
                        <div class="col-6 text-muted small">Date</div>
                        <div class="col-6 fw-semibold">@Model.BookingDate.ToString("MMMM d, yyyy")</div>
                        <div class="col-6 text-muted small">Time</div>
                        <div class="col-6 fw-semibold">@Model.StartTime.ToString("hh:mm tt") – @Model.EndTime.ToString("hh:mm tt")</div>
                        <div class="col-6 text-muted small">Duration</div>
                        <div class="col-6 fw-semibold">@Model.DurationHours hrs</div>
                        <div class="col-12"><hr class="my-2"></div>
                        <div class="col-6 fw-bold">Total Amount</div>
                        <div class="col-6 fw-bold text-success fs-5">₱@Model.TotalPrice.ToString("N0")</div>
                    </div>
                </div>
            </div>

            @* ── TempData alerts ── *@
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-exclamation-triangle-fill"></i> @err
                </div>
            }

            @* ── Instant Payment (PayMongo: Card / GCash / Maya / GrabPay / QRPh / Online Banking) ── *@
            @if (hasInstantPay)
            {
                <div class="card shadow-sm mb-4" style="border:1px solid rgba(163,255,18,0.2);">
                    <div class="card-header fw-bold" style="background:var(--cb-lime-dim);">
                        <i class="bi bi-lightning-charge-fill me-2" style="color:var(--cb-lime);"></i>Pay Instantly
                        <span class="badge ms-2" style="background:var(--cb-lime);color:#000;font-size:.7rem;">Confirmed in seconds</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-3" style="font-size:.875rem;color:var(--cb-text-2);">
                            Secure checkout powered by <strong>PayMongo</strong> — your booking is confirmed
                            <strong>automatically</strong> the moment your payment is received.
                        </p>

                        <div class="d-flex flex-wrap gap-2 mb-3" aria-label="Accepted payment methods">
                            @if (m("gcash"))    { <span class="badge bg-primary"><i class="bi bi-phone me-1"></i>GCash</span> }
                            @if (m("paymaya"))  { <span class="badge bg-success"><i class="bi bi-phone me-1"></i>Maya</span> }
                            @if (m("grab_pay")) { <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle"><i class="bi bi-car-front me-1"></i>GrabPay</span> }
                            @if (m("qrph"))     { <span class="badge bg-warning text-dark"><i class="bi bi-qr-code me-1"></i>QRPh (InstaPay)</span> }
                            @if (m("dob"))      { <span class="badge bg-info text-dark"><i class="bi bi-bank me-1"></i>Online Banking</span> }
                            @if (m("card"))     { <span class="badge bg-dark"><i class="bi bi-credit-card-2-front me-1"></i>Visa / Mastercard</span> }
                            @if (m("billease")) { <span class="badge bg-secondary"><i class="bi bi-cash-coin me-1"></i>BillEase</span> }
                        </div>

                        <form asp-action="PayWithGateway" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@Model.Id" />
                            <button type="submit" class="btn btn-lg w-100 fw-bold"
                                    style="background:var(--cb-lime);color:#000;">
                                <i class="bi bi-shield-lock-fill me-2"></i>Pay ₱@Model.TotalPrice.ToString("N0") Securely
                            </button>
                        </form>

                        <div class="text-center mt-3" style="font-size:.75rem;color:var(--cb-text-3);">
                            <i class="bi bi-lock-fill me-1"></i>
                            256-bit TLS. Payment data never touches CourtBook's servers.
                        </div>
                    </div>
                </div>
            }

            @if (!hasInstantPay && !hasGCash && !hasMaya)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Payment details have not been set up yet. Please contact the facility to arrange payment.
                </div>
            }
            else if (showManualPay)
            {
                <!-- Payment Instructions -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-send me-2 text-success"></i>Send Payment To
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(settings.PaymentInstructions))
                        {
                            <div class="alert alert-info py-2 mb-3">
                                <i class="bi bi-info-circle me-1"></i>@settings.PaymentInstructions
                            </div>
                        }

                        <div class="row g-3">
                            @if (hasGCash)
                            {
                                <div class="col-sm-6">
                                    <div class="border rounded p-3 text-center bg-light h-100">
                                        <div class="fw-bold text-primary mb-2">
                                            <i class="bi bi-phone me-1"></i>GCash
                                        </div>
                                        @if (hasGCashQr)
                                        {
                                            <img src="@settings.GCashQrCodePath" alt="GCash QR Code"
                                                 style="max-width:200px;width:100%;border-radius:8px;margin-bottom:.5rem;" />
                                        }
                                        <div class="fs-5 fw-bold">@settings.GCashNumber</div>
                                        @if (!string.IsNullOrWhiteSpace(settings.GCashName))
                                        {
                                            <div class="text-muted small">@settings.GCashName</div>
                                        }
                                        @if (hasGCashQr)
                                        {
                                            <div class="mt-2">
                                                <a href="@settings.GCashQrCodePath" download class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-download me-1"></i>Save QR Code
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            @if (hasMaya)
                            {
                                <div class="col-sm-6">
                                    <div class="border rounded p-3 text-center bg-light h-100">
                                        <div class="fw-bold text-success mb-2">
                                            <i class="bi bi-phone me-1"></i>Maya
                                        </div>
                                        @if (hasMayaQr)
                                        {
                                            <img src="@settings.MayaQrCodePath" alt="Maya QR Code"
                                                 style="max-width:200px;width:100%;border-radius:8px;margin-bottom:.5rem;" />
                                        }
                                        <div class="fs-5 fw-bold">@settings.MayaNumber</div>
                                        @if (!string.IsNullOrWhiteSpace(settings.MayaName))
                                        {
                                            <div class="text-muted small">@settings.MayaName</div>
                                        }
                                        @if (hasMayaQr)
                                        {
                                            <div class="mt-2">
                                                <a href="@settings.MayaQrCodePath" download class="btn btn-sm btn-outline-success">
                                                    <i class="bi bi-download me-1"></i>Save QR Code
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="alert alert-warning mt-3 py-2 mb-0 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Send exactly <strong>₱@Model.TotalPrice.ToString("N0")</strong> and include your booking reference in the notes/remarks.
                        </div>
                    </div>
                </div>

                <!-- Submit Proof Form -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white fw-bold">
                        <i class="bi bi-check2-circle me-2 text-primary"></i>Submit Payment Proof
                    </div>
                    <div class="card-body">
                        <form asp-action="SubmitProof" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Payment Method</label>
                                <select name="method" class="form-select" required>
                                    @if (hasGCash) { <option value="GCash">GCash</option> }
                                    @if (hasMaya)  { <option value="Maya">Maya</option> }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Transaction / Reference Number <span class="text-danger">*</span></label>
                                <input type="text" name="reference" class="form-control" placeholder="e.g. 1234567890"
                                       required maxlength="100" />
                                <div class="form-text">Enter the reference number from your GCash/Maya transaction.</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Screenshot (optional)</label>
                                <input type="file" name="screenshot" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                                <div class="form-text">Upload a screenshot of your payment confirmation (JPG, PNG, or WebP).</div>
                            </div>

                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-check-circle me-2"></i>Submit Payment Proof
                            </button>
                        </form>
                    </div>
                </div>
            }

            <div class="text-center">
                <a asp-action="My" class="btn btn-link text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Back to My Bookings
                </a>
            </div>
        </div>
    </div>
</div>
