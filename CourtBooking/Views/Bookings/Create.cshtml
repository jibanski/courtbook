@model CourtBooking.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Confirm Booking";
    var facilityName = ViewBag.FacilityName as string;
}

<div class="cb-page-header">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0" style="font-size:.825rem;">
                <li class="breadcrumb-item"><a href="/" style="color:var(--cb-text-3);text-decoration:none;">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Courts" asp-action="Index" style="color:var(--cb-text-3);text-decoration:none;">Courts</a></li>
                <li class="breadcrumb-item active" style="color:var(--cb-text-2);">Book @Model.Court?.Name</li>
            </ol>
        </nav>
        <h1 class="mb-0 cb-fade-up" style="font-size:1.75rem;">
            <i class="bi bi-calendar-plus me-2" style="color:var(--cb-lime);"></i>Book a Court
        </h1>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0 fw-bold">@Model.Court?.Name — @Model.Court?.SportType</h5>
                    @if (!string.IsNullOrWhiteSpace(facilityName))
                    {
                        <div class="text-muted small mt-1">
                            <i class="bi bi-buildings me-1"></i>@facilityName
                        </div>
                    }
                    <small class="text-muted">Rate: ₱@Model.Court?.PricePerHour.ToString("N0")/hour</small>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CourtId" />
                        @if (Model.IsSlotBooking)
                        {
                            <input type="hidden" asp-for="FixedEndHour" />
                        }

                        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="mb-3">
                            <label asp-for="BookingDate" class="form-label fw-semibold">Date</label>
                            <input asp-for="BookingDate" type="date" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   max="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="BookingDate" class="text-danger small"></span>
                        </div>

                        @if (Model.IsSlotBooking)
                        {
                            <!-- Fixed slot: show read-only time and price -->
                            <input type="hidden" asp-for="StartHour" />
                            <input type="hidden" asp-for="DurationHours" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Time Slot</label>
                                <div class="form-control bg-light fw-semibold">
                                    <i class="bi bi-clock me-2 text-primary"></i>
                                    @Model.StartHour.ToString("D2"):00 – @Model.FixedEndHour!.Value.ToString("D2"):00
                                    <span class="text-muted fw-normal ms-2">(@Model.TotalPrice.ToString("N0") total)</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="StartHour" class="form-label fw-semibold">Start Time</label>
                                <select asp-for="StartHour" class="form-select" id="startHourSelect">
                                    @for (int h = (Model.Court?.OpeningHour ?? 6); h < (Model.Court?.ClosingHour ?? 22); h++)
                                    {
                                        <option value="@h" selected="@(Model.StartHour == h)">@h.ToString("D2"):00</option>
                                    }
                                </select>
                                <span asp-validation-for="StartHour" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="DurationHours" class="form-label fw-semibold">Duration</label>
                                <select asp-for="DurationHours" class="form-select" id="durationSelect">
                                    <option value="1">1 hour</option>
                                    <option value="2">2 hours</option>
                                    <option value="3">3 hours</option>
                                    <option value="4">4 hours</option>
                                </select>
                                <span asp-validation-for="DurationHours" class="text-danger small"></span>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label fw-semibold">Notes <span class="text-muted fw-normal">(optional)</span></label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any special requests..."></textarea>
                        </div>

                        <!-- Price Summary -->
                        <div class="alert alert-primary">
                            <div class="d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-receipt me-2"></i><strong>Total</strong></span>
                                <span class="fs-5 fw-bold" id="totalPrice">₱@Model.TotalPrice.ToString("N0")</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                            <a asp-controller="Courts" asp-action="Details" asp-route-id="@Model.CourtId" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-1"></i>Confirm Booking
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@if (!Model.IsSlotBooking)
{
<script>
    const pricePerHour = @Model.Court?.PricePerHour;
    function updatePrice() {
        const duration = parseInt(document.getElementById('durationSelect').value);
        document.getElementById('totalPrice').textContent = '₱' + (pricePerHour * duration).toLocaleString();
    }
    document.getElementById('durationSelect').addEventListener('change', updatePrice);
</script>
}
}
