@{
    ViewData["Title"] = "CourtBook";
    Layout = "_LandingLayout";
}

<section class="min-vh-100 d-flex align-items-center bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 text-center">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle rounded-circle mb-3"
                         style="width:96px;height:96px;">
                        <i class="bi bi-check-circle-fill text-success" style="font-size:3rem;"></i>
                    </div>
                    <h2 class="fw-bold mb-2">You're all good!</h2>
                    <p class="text-muted lead">
                        CourtBook is <strong>completely free</strong>. There's no trial period and no subscription needed — your account is active forever.
                    </p>
                </div>

                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-lg fw-bold px-5 mb-3">
                    <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                </a>

                <p class="text-muted small mt-3">
                    If CourtBook has been helpful, feel free to
                    <a asp-controller="Home" asp-action="Donate">support us with a small donation</a> — but there's absolutely no pressure. 🙏
                </p>
            </div>
        </div>
    </div>
</section>
