@model CourtBooking.ViewModels.TrialRegistrationViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_LandingLayout";
    var schemes = await Context.RequestServices
        .GetRequiredService<Microsoft.AspNetCore.Authentication.IAuthenticationSchemeProvider>()
        .GetAllSchemesAsync();
    bool hasGoogle   = schemes.Any(s => s.Name == "Google");
    bool hasFacebook = schemes.Any(s => s.Name == "Facebook");
    bool hasSocial   = hasGoogle || hasFacebook;
}

<section class="py-5 min-vh-100 d-flex align-items-center"
         style="background:var(--cb-bg);">
    <div class="container">
        <div class="row justify-content-center">

            <!-- ── Registration card ──────────────────────────────────── -->
            <div class="col-lg-5 col-md-7">
                <div class="mb-4">
                    <a asp-controller="Home" asp-action="Index"
                       style="color:var(--cb-text-3);text-decoration:none;font-size:.82rem;display:inline-flex;align-items:center;gap:.4rem;">
                        <i class="bi bi-arrow-left"></i>Back to home
                    </a>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-3 mb-2"
                                  style="width:52px;height:52px;background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.25);">
                                <i class="bi bi-lightning-charge-fill fs-4" style="color:var(--cb-lime);"></i>
                            </span>
                            <h2 class="fw-bold mt-1 mb-1">Create Your Account</h2>
                            <p style="color:var(--cb-text-3);font-size:.875rem;">Choose how you'll use CourtBook.</p>
                        </div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger small">
                                <ul class="mb-0 ps-3">
                                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@err.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <form asp-action="Start" method="post" id="regForm" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <!-- ── Role selector ─────────────────────────── -->
                            <input type="hidden" asp-for="Role" id="roleInput" />

                            <div class="row g-3 mb-4">
                                <!-- Facility Owner card -->
                                <div class="col-6">
                                    <div id="cardAdmin"
                                         class="role-card @(Model.Role == "Admin" ? "role-card-active" : "")"
                                         onclick="selectRole('Admin')">
                                        <div class="role-icon mb-2"
                                             style="background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.25);color:var(--cb-lime);">
                                            <i class="bi bi-buildings fs-4"></i>
                                        </div>
                                        <div class="fw-bold small">Facility Owner</div>
                                        <div style="color:var(--cb-text-3);font-size:.72rem;">Manage courts &amp; bookings</div>
                                        <div class="mt-2">
                                            <span class="badge" style="background:rgba(163,255,18,0.12);color:var(--cb-lime);font-size:.65rem;">
                                                <i class="bi bi-check-circle me-1"></i>Free Forever
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Customer card -->
                                <div class="col-6">
                                    <div id="cardCustomer"
                                         class="role-card @(Model.Role == "Customer" ? "role-card-active" : "")"
                                         onclick="selectRole('Customer')">
                                        <div class="role-icon mb-2"
                                             style="background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.25);color:#4ade80;">
                                            <i class="bi bi-person-running fs-4"></i>
                                        </div>
                                        <div class="fw-bold small">Player / Customer</div>
                                        <div style="color:var(--cb-text-3);font-size:.72rem;">Browse &amp; book courts</div>
                                        <div class="mt-2">
                                            <span class="badge" style="background:var(--cb-lime-dim);color:var(--cb-lime);font-size:.65rem;">
                                                <i class="bi bi-check-circle me-1"></i>Free Forever
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @* ── Social login (Customer role only) ── *@
                            @if (hasSocial)
                            {
                                <div id="socialSection" class="@(Model.Role == "Admin" ? "d-none" : "")">
                                    <div class="d-flex flex-column gap-2 mb-3">
                                        @if (hasGoogle)
                                        {
                                            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="provider" value="Google" />
                                                <input type="hidden" name="returnUrl" value="" />
                                                <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold"
                                                        style="background:var(--cb-surface-2);border:1px solid var(--cb-border);color:var(--cb-text);font-size:.9rem;">
                                                    <svg width="18" height="18" viewBox="0 0 48 48">
                                                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                                    </svg>
                                                    Continue with Google
                                                </button>
                                            </form>
                                        }
                                        @if (hasFacebook)
                                        {
                                            <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="provider" value="Facebook" />
                                                <input type="hidden" name="returnUrl" value="" />
                                                <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold"
                                                        style="background:#1877f2;border:none;color:#fff;font-size:.9rem;">
                                                    <i class="bi bi-facebook fs-5"></i>
                                                    Continue with Facebook
                                                </button>
                                            </form>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center gap-2 mb-3">
                                        <hr class="flex-grow-1 m-0" />
                                        <span style="color:var(--cb-text-3);font-size:.78rem;white-space:nowrap;">or register with email</span>
                                        <hr class="flex-grow-1 m-0" />
                                    </div>
                                </div>
                            }

                            <!-- ── Facility name (Admin only) ─────────────── -->
                            <div id="facilityNameGroup" class="mb-3 @(Model.Role != "Admin" ? "d-none" : "")">
                                <label asp-for="FacilityName" class="form-label fw-semibold small">
                                    <i class="bi bi-buildings me-1" style="color:var(--cb-lime);"></i>Facility / Business Name
                                </label>
                                <input asp-for="FacilityName" class="form-control"
                                       placeholder="e.g. Greenfield Sports Complex" />
                                <span asp-validation-for="FacilityName" class="text-danger small"></span>

                                <label asp-for="FacilityAddress" class="form-label fw-semibold small mt-3">
                                    <i class="bi bi-geo-alt me-1" style="color:var(--cb-lime);"></i>Facility Address
                                    <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Optional</span>
                                </label>
                                <input asp-for="FacilityAddress" class="form-control"
                                       placeholder="e.g. 123 Rizal St., Brgy. San Roque, Quezon City" />
                                <span asp-validation-for="FacilityAddress" class="text-danger small"></span>

                                <label asp-for="BrandTagline" class="form-label fw-semibold small mt-3">
                                    <i class="bi bi-chat-quote me-1" style="color:var(--cb-lime);"></i>Tagline
                                    <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Optional</span>
                                </label>
                                <input asp-for="BrandTagline" class="form-control"
                                       placeholder="e.g. Book your court anytime, anywhere." maxlength="200" />
                                <span asp-validation-for="BrandTagline" class="text-danger small"></span>

                                <label asp-for="BrandLogo" class="form-label fw-semibold small mt-3">
                                    <i class="bi bi-image me-1" style="color:var(--cb-lime);"></i>Logo
                                    <span class="badge bg-secondary ms-1" style="font-size:.6rem;">Optional</span>
                                </label>
                                <input asp-for="BrandLogo" type="file" class="form-control"
                                       accept=".jpg,.jpeg,.png,.webp,.svg" />
                                <div class="form-text small" style="color:var(--cb-text-3);">JPG, PNG, WebP, or SVG. Square images look best.</div>
                                <span asp-validation-for="BrandLogo" class="text-danger small"></span>
                            </div>

                            <!-- ── Payment details (Admin only, optional) ─────────────── -->
                            <div id="paymentDetailsGroup" class="mb-3 @(Model.Role != "Admin" ? "d-none" : "")">
                                <div class="border rounded p-3" style="background:rgba(163,255,18,0.04);border-color:rgba(163,255,18,0.15)!important;">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <label class="form-label fw-semibold small mb-0">
                                            <i class="bi bi-wallet2 me-1" style="color:var(--cb-lime);"></i>Manual Payment Details
                                        </label>
                                        <span class="badge bg-secondary" style="font-size:.65rem;">Optional</span>
                                    </div>
                                    <p class="small mb-3" style="color:var(--cb-text-3);">
                                        Customers can pay you directly via GCash or Maya. You can also add these later in Settings.
                                    </p>
                                    <div class="row g-2">
                                        <div class="col-7">
                                            <label asp-for="GCashNumber" class="form-label small mb-1">GCash Number</label>
                                            <input asp-for="GCashNumber" class="form-control form-control-sm" placeholder="09XX XXX XXXX" />
                                            <span asp-validation-for="GCashNumber" class="text-danger small"></span>
                                        </div>
                                        <div class="col-5">
                                            <label asp-for="GCashName" class="form-label small mb-1">Account Name</label>
                                            <input asp-for="GCashName" class="form-control form-control-sm" placeholder="Juan D." />
                                            <span asp-validation-for="GCashName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-7">
                                            <label asp-for="MayaNumber" class="form-label small mb-1">Maya Number</label>
                                            <input asp-for="MayaNumber" class="form-control form-control-sm" placeholder="09XX XXX XXXX" />
                                            <span asp-validation-for="MayaNumber" class="text-danger small"></span>
                                        </div>
                                        <div class="col-5">
                                            <label asp-for="MayaName" class="form-label small mb-1">Account Name</label>
                                            <input asp-for="MayaName" class="form-control form-control-sm" placeholder="Juan D." />
                                            <span asp-validation-for="MayaName" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ── Common fields ──────────────────────────── -->
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <label asp-for="FirstName" class="form-label fw-semibold small">First Name</label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-6">
                                    <label asp-for="LastName" class="form-label fw-semibold small">Last Name</label>
                                    <input asp-for="LastName" class="form-control" placeholder="Dela Cruz" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-semibold small">
                                    <i class="bi bi-envelope me-1" style="color:var(--cb-lime);"></i>Email Address
                                </label>
                                <input asp-for="Email" type="email" class="form-control"
                                       placeholder="you@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold small">
                                    <i class="bi bi-lock me-1" style="color:var(--cb-lime);"></i>Password
                                </label>
                                <input asp-for="Password" type="password" class="form-control"
                                       placeholder="At least 6 characters" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label fw-semibold small">Confirm Password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control"
                                       placeholder="Repeat your password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    <input asp-for="AgreeToPrivacyPolicy" class="form-check-input" type="checkbox" required />
                                    <label asp-for="AgreeToPrivacyPolicy" class="form-check-label small">
                                        I agree to the <a asp-controller="Home" asp-action="Privacy" target="_blank" style="color:var(--cb-lime);">Privacy Policy</a>
                                    </label>
                                    <span asp-validation-for="AgreeToPrivacyPolicy" class="text-danger small d-block"></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold" id="submitBtn">
                                <i class="bi bi-rocket-takeoff me-2" id="submitIcon"></i>
                                <span id="submitText">Create Account</span>
                            </button>

                            <p class="text-center small mt-3 mb-0" style="color:var(--cb-text-3);">
                                Already have an account?
                                <a asp-controller="Account" asp-action="Login" style="color:var(--cb-lime);font-weight:600;">Login here</a>
                            </p>
                        </form>
                    </div>
                </div>
            </div>

            <!-- ── Side panel ─────────────────────────────────────────── -->
            <div class="col-lg-4 d-none d-lg-block ps-lg-5 pt-2">

                <!-- Admin benefits -->
                <div id="panelAdmin" class="@(Model.Role != "Admin" ? "d-none" : "")">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div class="d-flex align-items-center justify-content-center rounded-3"
                             style="width:40px;height:40px;flex-shrink:0;background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.25);">
                            <i class="bi bi-buildings" style="color:var(--cb-lime);"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Facility Owner Account</div>
                            <div style="color:var(--cb-text-3);font-size:.8rem;">Free forever — full access, no credit card</div>
                        </div>
                    </div>
                    <ul class="list-unstyled">
                        @foreach (var item in new[] {
                            new { icon = "bi-calendar-check", text = "Online court booking system" },
                            new { icon = "bi-phone",          text = "GCash & Maya payments" },
                            new { icon = "bi-speedometer2",   text = "Admin dashboard & reports" },
                            new { icon = "bi-buildings",      text = "Unlimited court listings" },
                            new { icon = "bi-clock",          text = "Time slot management" },
                            new { icon = "bi-image",          text = "Court photo uploads" },
                        })
                        {
                            <li class="d-flex align-items-start mb-3">
                                <i class="bi @item.icon me-3 mt-1 fs-5" style="color:var(--cb-lime);"></i>
                                <span style="color:var(--cb-text-2);font-size:.875rem;">@item.text</span>
                            </li>
                        }
                    </ul>
                    <div class="rounded-3 p-3 mt-3"
                         style="background:rgba(163,255,18,0.07);border:1px solid rgba(163,255,18,0.2);">
                        <div class="fw-semibold small mb-1" style="color:var(--cb-lime);">
                            <i class="bi bi-shield-check me-1"></i>No risk, no commitment
                        </div>
                        <p style="color:var(--cb-text-3);font-size:.825rem;margin:0;">
                            CourtBook is free forever. No credit card, no subscription, no catch.
                        </p>
                    </div>
                </div>

                <!-- Customer benefits -->
                <div id="panelCustomer" class="@(Model.Role == "Admin" ? "d-none" : "")">
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <div class="d-flex align-items-center justify-content-center rounded-3"
                             style="width:40px;height:40px;flex-shrink:0;background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.25);">
                            <i class="bi bi-person-running" style="color:#4ade80;"></i>
                        </div>
                        <div>
                            <div class="fw-bold">Player Account</div>
                            <div style="color:var(--cb-text-3);font-size:.8rem;">Free forever — book courts instantly</div>
                        </div>
                    </div>
                    <ul class="list-unstyled">
                        @foreach (var item in new[] {
                            new { icon = "bi-search",        text = "Browse available courts" },
                            new { icon = "bi-calendar-plus", text = "Book any time slot online" },
                            new { icon = "bi-phone",         text = "Pay via GCash or Maya" },
                            new { icon = "bi-receipt",       text = "View all your bookings" },
                            new { icon = "bi-bell",          text = "Instant booking confirmation" },
                        })
                        {
                            <li class="d-flex align-items-start mb-3">
                                <i class="bi @item.icon me-3 mt-1 fs-5" style="color:var(--cb-lime);"></i>
                                <span style="color:var(--cb-text-2);font-size:.875rem;">@item.text</span>
                            </li>
                        }
                    </ul>
                    <div class="rounded-3 p-3 mt-3"
                         style="background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.2);">
                        <div class="fw-semibold small mb-1" style="color:var(--cb-lime);">
                            <i class="bi bi-gift me-1"></i>Completely Free
                        </div>
                        <p style="color:var(--cb-text-3);font-size:.825rem;margin:0;">
                            Creating a player account is always free. Book courts at any facility using CourtBook.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectRole(role) {
            document.getElementById('roleInput').value = role;

            const cardAdmin     = document.getElementById('cardAdmin');
            const cardCustomer  = document.getElementById('cardCustomer');
            const facilityGrp   = document.getElementById('facilityNameGroup');
            const paymentGrp    = document.getElementById('paymentDetailsGroup');
            const panelAdmin    = document.getElementById('panelAdmin');
            const panelCustomer = document.getElementById('panelCustomer');
            const submitIcon    = document.getElementById('submitIcon');
            const submitText    = document.getElementById('submitText');
            const socialSection = document.getElementById('socialSection');

            if (role === 'Admin') {
                cardAdmin.classList.add('role-card-active');
                cardCustomer.classList.remove('role-card-active');
                facilityGrp.classList.remove('d-none');
                paymentGrp.classList.remove('d-none');
                panelAdmin.classList.remove('d-none');
                panelCustomer.classList.add('d-none');
                submitIcon.className = 'bi bi-rocket-takeoff me-2';
                submitText.textContent = 'Create Account';
                if (socialSection) socialSection.classList.add('d-none');
            } else {
                cardCustomer.classList.add('role-card-active');
                cardAdmin.classList.remove('role-card-active');
                facilityGrp.classList.add('d-none');
                paymentGrp.classList.add('d-none');
                panelAdmin.classList.add('d-none');
                panelCustomer.classList.remove('d-none');
                submitIcon.className = 'bi bi-person-check me-2';
                submitText.textContent = 'Create Player Account';
                if (socialSection) socialSection.classList.remove('d-none');
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function () {
            selectRole(document.getElementById('roleInput').value || 'Customer');
        });
    </script>
}
