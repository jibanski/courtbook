<!-- ── Reviews ────────────────────────────────────────────────────────── -->
@if (hasRealReviews)
{
    var avgRating = realReviews.Average(r => r.Rating);
    var avgDisplay = avgRating.ToString("0.0");
    <section id="reviews" class="py-6 bg-white">
        <div class="container">
            <div class="text-center mb-5">
                <span class="badge bg-success-subtle text-success fw-semibold px-3 py-2 mb-2">Customer Reviews</span>
                <h2 class="fw-bold fs-1">Loved by facility owners</h2>
                <p class="text-muted lead">See what other sports facilities are saying about CourtBook.</p>
            </div>

            <div class="row g-4">
                @foreach (var r in realReviews)
                {
                    var initials = Initials(r.OwnerName);
                    var color    = AvatarColor(r.OwnerId);
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border rounded-4 shadow-sm p-4">
                            <div class="mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= r.Rating ? "bi-star-fill text-warning" : "bi-star text-secondary")"></i>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Title))
                            {
                                <h6 class="fw-bold mb-2">@r.Title</h6>
                            }
                            <p class="text-muted small mb-4 flex-grow-1">"@r.Body"</p>
                            <div class="d-flex align-items-center gap-3">
                                <div class="@color text-white rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:44px;height:44px;font-size:.85rem;">
                                    @initials
                                </div>
                                <div>
                                    <div class="fw-semibold small">@r.OwnerName</div>
                                    <div class="text-muted" style="font-size:.75rem;">@r.FacilityName</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary bar -->
            <div class="row justify-content-center mt-5">
                <div class="col-md-8">
                    <div class="bg-primary-subtle rounded-4 p-4 text-center">
                        <div class="d-flex justify-content-center gap-1 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill text-warning" : "bi-star text-secondary") fs-5"></i>
                            }
                        </div>
                        <div class="fw-bold fs-5">@avgDisplay out of 5</div>
                        <div class="text-muted small">Based on @realReviews.Count review@(realReviews.Count == 1 ? "" : "s") from facility owners across the Philippines</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

