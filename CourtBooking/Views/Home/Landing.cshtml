    <div class="container">
        <div class="text-center mb-5">
            <span class="badge mb-2 px-3 py-2" style="background:var(--cb-lime-dim);color:var(--cb-lime);border:1px solid rgba(163,255,18,0.2);font-size:.78rem;font-weight:600;letter-spacing:.08em;">FAQ</span>
            <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:var(--cb-text);letter-spacing:-0.02em;">Frequently Asked Questions</h2>
            <p style="color:var(--cb-text-3);font-size:1rem;">Everything you need to know before getting started.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex flex-column gap-3">

                    @foreach (var item in new[] {
                        new {
                            q = "Is CourtBook really free?",
                            a = "Yes — completely free. No credit card, no subscription, no trial period. Create your account and start managing your facility right away."
                        },
                        new {
                            q = "How do I accept payments from customers?",
                            a = "Customers pay via GCash or Maya. They upload a screenshot of their payment proof when booking, you verify it and confirm — no third-party payment gateway or extra fees involved."
                        },
                        new {
                            q = "How long does setup take?",
                            a = "Most facility owners are live in under 30 minutes. You create your account, add your courts with photos and pricing, and share your booking link. That's it."
                        },
                        new {
                            q = "Can I manage multiple courts and sports?",
                            a = "Yes. You can add as many courts as you need across any sport — badminton, basketball, tennis, futsal, volleyball, pickleball, and more. Each court has its own schedule and pricing."
                        },
                        new {
                            q = "Do my customers need to download an app?",
                            a = "No app needed. Customers book directly from your facility link on any browser. CourtBook also works as a Progressive Web App (PWA) — customers can add it to their home screen for an app-like experience."
                        },
                        new {
                            q = "How does CourtBook sustain itself if it's free?",
                            a = "CourtBook runs on voluntary donations from facility owners and players who find value in the platform. If it helps your business, we'd appreciate any support — but there's absolutely no obligation."
                        },
                        new {
                            q = "I'm not tech-savvy. Is CourtBook easy to use?",
                            a = "Absolutely. CourtBook was built with non-technical facility owners in mind. The dashboard is clean and straightforward — if you can use Facebook, you can use CourtBook."
                        },
                        new {
                            q = "How do I get help if I have a problem?",
                            a = "Email us at courtbooksolutions@gmail.com. We respond within 24 hours on business days."
                        },
                    })
                    {
                        var id = "faq-" + System.Math.Abs(item.q.GetHashCode());
                        <div class="rounded-3 overflow-hidden" style="background:var(--cb-surface);border:1px solid var(--cb-border);">
                            <button class="accordion-button collapsed w-100 text-start border-0 fw-semibold d-flex justify-content-between align-items-center gap-2 px-4 py-3"
                                    style="background:transparent;color:var(--cb-text);font-size:.9rem;"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@id">
                                <span>@item.q</span>
                                <i class="bi bi-chevron-down flex-shrink-0" style="color:var(--cb-lime);font-size:.8rem;transition:transform .2s;"></i>
                            </button>
                            <div id="@id" class="accordion-collapse collapse">
                                <div class="px-4 pb-3" style="color:var(--cb-text-2);font-size:.875rem;line-height:1.7;border-top:1px solid var(--cb-border);">
                                    <div class="pt-3">@item.a</div>
                                </div>
                            </div>
                        </div>
                    }

                </div>

                <p class="text-center mt-4" style="color:var(--cb-text-3);font-size:.875rem;">
                    Still have questions?
                    <a href="mailto:courtbooksolutions@gmail.com" style="color:var(--cb-lime);font-weight:600;text-decoration:none;">Email us</a> — we're happy to help.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ── Final CTA ──────────────────────────────────────────────────────── -->
<section style="padding:5rem 0;background:var(--cb-surface);border-top:1px solid rgba(163,255,18,0.12);position:relative;overflow:hidden;text-align:center;">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(163,255,18,0.06) 0%,transparent 70%);pointer-events:none;"></div>
    <div class="container" style="position:relative;">
        <h2 style="font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;color:var(--cb-text);letter-spacing:-0.03em;margin-bottom:1rem;">
            Ready to modernize your facility?
        </h2>
        <p style="color:var(--cb-text-2);font-size:1.05rem;margin-bottom:2.5rem;line-height:1.7;">
            Join facility owners who have moved their court bookings online.<br>
            Get started in minutes — free forever, no strings attached.
        </p>
        <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
           class="btn btn-primary btn-lg fw-bold px-5 py-3">
            <i class="bi bi-rocket-takeoff me-2"></i>Create Your Free Account Now
        </a>
        <p style="margin-top:1rem;color:var(--cb-text-3);font-size:.82rem;">
            No credit card &nbsp;·&nbsp; Free forever &nbsp;·&nbsp; Donation-supported
        </p>
    </div>
</section>
