@model IEnumerable<CourtBooking.Models.Review>
@{
    ViewData["Title"] = "CourtBook — Smart Court Booking for Your Facility";
    Layout = "_LandingLayout";

    var realReviews = Model?.ToList() ?? new List<CourtBooking.Models.Review>();
    var hasRealReviews = realReviews.Count > 0;

    // Deterministic avatar colours so a given owner always gets the same shade.
    string AvatarColor(string seed)
    {
        var palette = new[] { "bg-primary", "bg-success", "bg-warning", "bg-danger", "bg-info", "bg-purple", "bg-dark" };
        var hash = 0;
        foreach (var c in seed ?? "") hash = (hash * 31 + c) & 0x7fffffff;
        return palette[hash % palette.Length];
    }

    string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
        return ($"{parts[0][0]}{parts[^1][0]}").ToUpper();
    }
}

