@{
    ViewData["Title"] = "CourtBook — Smart Court Booking for Your Facility";
    Layout = "_LandingLayout";
}

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<section class="landing-hero d-flex align-items-center">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge bg-warning text-dark fw-semibold px-3 py-2 mb-3 fs-6">
                    <i class="bi bi-stars me-1"></i>7-Day Free Trial — No Credit Card Needed
                </span>
                <h1 class="display-4 fw-bold text-white lh-sm mb-4">
                    Run Your Sports Facility<br>
                    <span class="text-warning">Completely Online</span>
                </h1>
                <p class="lead text-white-75 mb-5">
                    CourtBook gives your sports facility a professional online booking system.
                    Accept reservations 24/7, collect digital payments, and manage every court
                    from one powerful dashboard — without the spreadsheets.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
                       class="btn btn-warning btn-lg fw-bold px-5 shadow">
                        <i class="bi bi-rocket-takeoff me-2"></i>Start Free Trial
                    </a>
                    <a href="#how-it-works"
                       class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-play-circle me-2"></i>See How It Works
                    </a>
                </div>
                <p class="text-white-50 small mt-3">
                    <i class="bi bi-shield-check me-1"></i>Full access for 7 days &nbsp;·&nbsp;
                    <i class="bi bi-credit-card me-1"></i>No credit card &nbsp;·&nbsp;
                    <i class="bi bi-x-circle me-1"></i>Cancel anytime
                </p>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <div class="hero-mockup shadow-lg rounded-4 overflow-hidden">
                    <div class="bg-dark text-white p-3 d-flex align-items-center gap-2">
                        <span class="dot bg-danger"></span>
                        <span class="dot bg-warning"></span>
                        <span class="dot bg-success"></span>
                        <span class="ms-2 small opacity-50">CourtBook Admin Dashboard</span>
                    </div>
                    <div class="bg-white p-4">
                        <div class="row g-2 mb-3">
                            <div class="col-6"><div class="mock-stat bg-primary text-white rounded p-3"><div class="fs-4 fw-bold">24</div><div class="small">Bookings Today</div></div></div>
                            <div class="col-6"><div class="mock-stat bg-success text-white rounded p-3"><div class="fs-4 fw-bold">₱18,400</div><div class="small">This Week</div></div></div>
                        </div>
                        <div class="bg-light rounded p-3 text-start">
                            <div class="fw-semibold small text-muted mb-2">UPCOMING BOOKINGS</div>
                            @foreach (var item in new[] {
                                new { name = "Miguel R.", court = "Court A – Tennis", time = "9:00 AM", badge = "Confirmed" },
                                new { name = "Ana C.", court = "Court B – Badminton", time = "10:00 AM", badge = "Pending" },
                                new { name = "John D.", court = "Court C – Basketball", time = "11:00 AM", badge = "Confirmed" },
                            })
                            {
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <div>
                                        <div class="fw-semibold small">@item.name</div>
                                        <div class="text-muted" style="font-size:.75rem;">@item.court · @item.time</div>
                                    </div>
                                    <span class="badge @(item.badge == "Confirmed" ? "bg-success" : "bg-warning text-dark")">@item.badge</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Social Proof Bar ───────────────────────────────────────────────── -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">24/7</div>
                <div class="text-muted small">Online Bookings</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">2 min</div>
                <div class="text-muted small">Setup Time</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">GCash &amp; Maya</div>
                <div class="text-muted small">Digital Payments</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">7 Days</div>
                <div class="text-muted small">Free Trial</div>
            </div>
        </div>
    </div>
</div>

<!-- ── Features ───────────────────────────────────────────────────────── -->
<section id="features" class="py-6">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary-subtle text-primary fw-semibold px-3 py-2 mb-2">Features</span>
            <h2 class="fw-bold fs-1">Everything you need to run your facility</h2>
            <p class="text-muted lead">From first booking to payment confirmation — fully automated.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-primary-subtle text-primary mb-3">
                        <i class="bi bi-calendar-check fs-4"></i>
                    </div>
                    <h5 class="fw-bold">Online Court Booking</h5>
                    <p class="text-muted small mb-0">
                        Customers can browse courts and book their slot online anytime —
                        no phone calls, no manual scheduling.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-success-subtle text-success mb-3">
                        <i class="bi bi-phone fs-4"></i>
                    </div>
                    <h5 class="fw-bold">GCash &amp; Maya Payments</h5>
                    <p class="text-muted small mb-0">
                        Accept digital payments through GCash and Maya.
                        Customers submit payment proof — you confirm and get paid.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-warning-subtle text-warning mb-3">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                    <h5 class="fw-bold">Real-Time Availability</h5>
                    <p class="text-muted small mb-0">
                        Customers see exactly which time slots are open.
                        No double-bookings, no conflicts — ever.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-info-subtle text-info mb-3">
                        <i class="bi bi-speedometer2 fs-4"></i>
                    </div>
                    <h5 class="fw-bold">Admin Dashboard</h5>
                    <p class="text-muted small mb-0">
                        Monitor bookings, revenue, court utilization, and pending payments
                        from one clean, real-time dashboard.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-danger-subtle text-danger mb-3">
                        <i class="bi bi-buildings fs-4"></i>
                    </div>
                    <h5 class="fw-bold">Multi-Court Management</h5>
                    <p class="text-muted small mb-0">
                        Manage unlimited courts, each with its own schedule, pricing,
                        sport type, and availability settings.
                    </p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="feature-card h-100 p-4 rounded-4 border bg-white shadow-sm">
                    <div class="feature-icon bg-purple-subtle text-purple mb-3">
                        <i class="bi bi-phone-fill fs-4"></i>
                    </div>
                    <h5 class="fw-bold">Mobile-Friendly</h5>
                    <p class="text-muted small mb-0">
                        Works perfectly on any device. Customers book from their phones,
                        you manage from anywhere.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── How It Works ───────────────────────────────────────────────────── -->
<section id="how-it-works" class="py-6 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-success-subtle text-success fw-semibold px-3 py-2 mb-2">Simple Setup</span>
            <h2 class="fw-bold fs-1">Up and running in minutes</h2>
            <p class="text-muted lead">No technical knowledge required. Just sign up and go.</p>
        </div>
        <div class="row g-4 align-items-start">
            <div class="col-md-3 text-center">
                <div class="step-circle bg-primary text-white mx-auto mb-3">1</div>
                <h6 class="fw-bold">Create Your Account</h6>
                <p class="text-muted small">Sign up with your facility name and email. Your 7-day free trial starts immediately.</p>
            </div>
            <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center pt-2">
                <i class="bi bi-arrow-right fs-3 text-muted"></i>
            </div>
            <div class="col-md-3 text-center">
                <div class="step-circle bg-primary text-white mx-auto mb-3">2</div>
                <h6 class="fw-bold">Add Your Courts</h6>
                <p class="text-muted small">Set up your courts with photos, pricing, sport types, and operating hours.</p>
            </div>
            <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center pt-2">
                <i class="bi bi-arrow-right fs-3 text-muted"></i>
            </div>
            <div class="col-md-3 text-center">
                <div class="step-circle bg-success text-white mx-auto mb-3">3</div>
                <h6 class="fw-bold">Start Accepting Bookings</h6>
                <p class="text-muted small">Share your link. Customers book and pay online. You confirm and earn.</p>
            </div>
        </div>
    </div>
</section>

<!-- ── Pricing ────────────────────────────────────────────────────────── -->
<section id="pricing" class="py-6">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-warning-subtle text-warning fw-semibold px-3 py-2 mb-2">Pricing</span>
            <h2 class="fw-bold fs-1">Start free. Upgrade when you're ready.</h2>
            <p class="text-muted lead">No hidden fees. Simple, transparent pricing for every facility.</p>
        </div>
        <div class="row justify-content-center g-4">

            <!-- Free Trial -->
            <div class="col-md-4">
                <div class="pricing-card h-100 border rounded-4 p-4 bg-white shadow-sm d-flex flex-column">
                    <div class="mb-3">
                        <span class="badge bg-success-subtle text-success fw-semibold mb-2">Free Trial</span>
                        <div class="display-5 fw-bold mb-1">₱0</div>
                        <p class="text-muted small mb-0">Full access for 7 days.<br>No credit card required.</p>
                    </div>
                    <hr class="my-3" />
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        @foreach (var f in new[] {
                            "Unlimited courts",
                            "Online booking system",
                            "GCash & Maya payments",
                            "Admin dashboard",
                            "Time slot management",
                            "Court photo uploads",
                            "Mobile-friendly"
                        })
                        {
                            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-success me-2"></i>@f</li>
                        }
                    </ul>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
                       class="btn btn-outline-success w-100 fw-semibold mt-auto">
                        <i class="bi bi-rocket-takeoff me-2"></i>Start Free Trial
                    </a>
                </div>
            </div>

            <!-- Starter — Monthly -->
            <div class="col-md-4">
                <div class="pricing-card h-100 border rounded-4 p-4 bg-white shadow-sm d-flex flex-column">
                    <div class="mb-3">
                        <span class="badge bg-primary-subtle text-primary fw-semibold mb-2">Starter</span>
                        <div class="display-5 fw-bold mb-1">₱799<small class="fs-6 fw-normal text-muted">/mo</small></div>
                        <p class="text-muted small mb-0">Billed monthly.<br>Cancel anytime.</p>
                    </div>
                    <hr class="my-3" />
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        @foreach (var f in new[] {
                            "Everything in Free Trial",
                            "Uninterrupted access",
                            "Custom facility branding",
                            "Priority support",
                            "All future updates",
                            "Flexible month-to-month",
                        })
                        {
                            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-primary me-2"></i>@f</li>
                        }
                    </ul>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
                       class="btn btn-primary w-100 fw-semibold mt-auto">
                        <i class="bi bi-arrow-up-circle me-2"></i>Get Started
                    </a>
                </div>
            </div>

            <!-- Pro — Annual -->
            <div class="col-md-4">
                <div class="pricing-card h-100 border-primary border-2 rounded-4 p-4 bg-white shadow position-relative d-flex flex-column">
                    <span class="badge bg-primary position-absolute top-0 start-50 translate-middle px-3 py-2 fw-semibold">
                        🏆 Best Value
                    </span>
                    <div class="mb-3 mt-2">
                        <span class="badge bg-warning text-dark fw-semibold mb-2">Pro Annual</span>
                        <div class="display-5 fw-bold mb-1">
                            ₱632<small class="fs-6 fw-normal text-muted">/mo</small>
                        </div>
                        <p class="text-muted small mb-0">
                            Billed ₱7,588/year.
                            <span class="text-success fw-semibold">Save ₱2,000</span> vs monthly.
                        </p>
                    </div>
                    <hr class="my-3" />
                    <ul class="list-unstyled mb-4 flex-grow-1">
                        @foreach (var f in new[] {
                            "Everything in Starter",
                            "Lowest price per month",
                            "Custom facility branding",
                            "Priority support",
                            "All future updates",
                            "2+ months free vs monthly",
                        })
                        {
                            <li class="mb-2 small"><i class="bi bi-check-circle-fill text-warning me-2"></i>@f</li>
                        }
                    </ul>
                    <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
                       class="btn btn-primary w-100 fw-bold mt-auto">
                        <i class="bi bi-stars me-2"></i>Get Pro Annual
                    </a>
                    <p class="text-center text-muted mt-2 mb-0" style="font-size:.75rem;">
                        <i class="bi bi-shield-check me-1 text-success"></i>30-day money-back guarantee
                    </p>
                </div>
            </div>

        </div>

        <!-- Reassurance note -->
        <p class="text-center text-muted small mt-4 mb-0">
            <i class="bi bi-info-circle me-1"></i>
            All plans include the same full-featured system. Upgrade or switch billing anytime after your trial.
        </p>
    </div>
</section>

<!-- ── Final CTA ──────────────────────────────────────────────────────── -->
<section class="landing-cta py-6 text-center text-white">
    <div class="container">
        <h2 class="display-5 fw-bold mb-3">Ready to modernize your facility?</h2>
        <p class="lead text-white-75 mb-5">
            Join facility owners who have moved their court bookings online.<br>
            Get started in minutes — completely free for 7 days.
        </p>
        <a asp-controller="Trial" asp-action="Start" asp-route-role="Admin"
           class="btn btn-warning btn-lg fw-bold px-5 py-3 shadow-lg">
            <i class="bi bi-rocket-takeoff me-2"></i>Start Your Free Trial Now
        </a>
        <p class="mt-3 text-white-50 small">
            No credit card &nbsp;·&nbsp; Full access &nbsp;·&nbsp; Cancel anytime
        </p>
    </div>
</section>
