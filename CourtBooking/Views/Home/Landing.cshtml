                <h6 style="font-weight:700;color:var(--cb-text);">Start Accepting Bookings</h6>
                <p style="color:var(--cb-text-3);font-size:.85rem;">Share your link. Customers book and pay online. You confirm and earn.</p>
            </div>
        </div>
    </div>
</section>

<!-- ── Reviews ────────────────────────────────────────────────────────── -->
@if (hasRealReviews)
{
    var avgRating = realReviews.Average(r => r.Rating);
    var avgDisplay = avgRating.ToString("0.0");
    <section id="reviews" style="padding:5rem 0;background:var(--cb-bg);">
        <div class="container">
            <div class="text-center mb-5">
                <span class="badge mb-2 px-3 py-2" style="background:var(--cb-lime-dim);color:var(--cb-lime);border:1px solid rgba(163,255,18,0.2);font-size:.78rem;font-weight:600;letter-spacing:.08em;">Customer Reviews</span>
                <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:var(--cb-text);letter-spacing:-0.02em;">Loved by facility owners</h2>
                <p style="color:var(--cb-text-3);font-size:1rem;">See what other sports facilities are saying about CourtBook.</p>
            </div>

            <div class="row g-4">
                @foreach (var r in realReviews)
                {
                    var initials = Initials(r.OwnerName);
                    var color    = AvatarColor(r.OwnerId);
                    <div class="col-md-6 col-lg-4">
                        <div class="h-100 rounded-4 p-4 d-flex flex-column" style="background:var(--cb-surface);border:1px solid var(--cb-border);">
                            <div class="mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= r.Rating ? "bi-star-fill" : "bi-star")" style="color:@(i <= r.Rating ? "#f59e0b" : "var(--cb-text-3)");"></i>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Title))
                            {
                                <h6 style="font-weight:700;color:var(--cb-text);margin-bottom:.5rem;">@r.Title</h6>
                            }
                            <p style="color:var(--cb-text-2);font-size:.875rem;line-height:1.65;margin-bottom:1.25rem;flex-grow:1;">"@r.Body"</p>
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex align-items-center justify-content-center rounded-circle fw-bold flex-shrink-0"
                                     style="width:44px;height:44px;font-size:.85rem;background:rgba(163,255,18,0.15);color:var(--cb-lime);">
                                    @initials
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:.875rem;color:var(--cb-text);">@r.OwnerName</div>
                                    <div style="font-size:.75rem;color:var(--cb-text-3);">@r.FacilityName</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Summary bar -->
            <div class="row justify-content-center mt-5">
                <div class="col-md-8">
                    <div class="rounded-4 p-4 text-center" style="background:var(--cb-lime-dim);border:1px solid rgba(163,255,18,0.2);">
                        <div class="d-flex justify-content-center gap-1 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star") fs-5" style="color:@(i <= Math.Round(avgRating) ? "#f59e0b" : "var(--cb-text-3)");"></i>
                            }
                        </div>
                        <div style="font-weight:700;font-size:1.1rem;color:var(--cb-lime);">@avgDisplay out of 5</div>
                        <div style="color:var(--cb-text-3);font-size:.82rem;">Based on @realReviews.Count review@(realReviews.Count == 1 ? "" : "s") from facility owners across the Philippines</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

